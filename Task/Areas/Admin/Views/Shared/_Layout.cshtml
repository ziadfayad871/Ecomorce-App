@{
    var pageTitle = ViewData["Title"] as string ?? "لوحة إدارة متجر الملابس";
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isDashboardPage =
        string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentController, "Dashboard", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var isDataSectionOpen = string.Equals(currentController, "Users", StringComparison.OrdinalIgnoreCase);

    string GetNavClass(string controller, string action)
    {
        var isActive =
            string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return isActive
            ? "flex items-center justify-between rounded-xl bg-admin-700 px-4 py-2.5 text-sm font-bold text-white shadow-sm"
            : "flex items-center justify-between rounded-xl px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-admin-50 hover:text-admin-700";
    }
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Ecomorce App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    colors: {
                        admin: {
                            50: "#ecfeff",
                            100: "#cffafe",
                            500: "#06b6d4",
                            700: "#0e7490",
                            900: "#164e63"
                        }
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Task.styles.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-slate-100 font-sans text-slate-800 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-24 right-10 h-96 w-96 rounded-full bg-admin-100 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 h-72 w-72 -translate-x-20 translate-y-20 rounded-full bg-cyan-200/70 blur-3xl"></div>
    </div>

    <div class="mx-auto min-h-screen max-w-[1600px] px-4 py-4 sm:px-6 lg:px-8">
        <div class="grid gap-4 lg:grid-cols-[18rem_minmax(0,1fr)]">
            <aside class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm lg:sticky lg:top-4 lg:h-[calc(100vh-2rem)] lg:overflow-y-auto">
                <div class="border-b border-slate-200 pb-4">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-xl font-extrabold text-admin-900">لوحة الإدارة</a>
                    <p class="mt-1 text-xs font-semibold text-slate-500">Fashion Store Control Panel</p>
                </div>

                @if (isAuthenticated)
                {
                    <nav class="mt-5 space-y-5">
                        <div class="space-y-2">
                            <p class="px-2 text-xs font-extrabold tracking-[0.2em] text-slate-400">MAIN</p>
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="@GetNavClass("Dashboard", "Index")">
                                <span>Dashboard</span>
                            </a>
                        </div>

                        <div class="space-y-2">
                            <p class="px-2 text-xs font-extrabold tracking-[0.2em] text-slate-400">إدارة المتجر</p>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="@GetNavClass("Products", "Index")">
                                <span>المنتجات</span>
                            </a>
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="@GetNavClass("Categories", "Index")">
                                <span>التصنيفات</span>
                            </a>
                        </div>

                        <details class="group rounded-2xl border border-slate-200/80 bg-slate-50/60 p-2" @(isDataSectionOpen ? "open" : null)>
                            <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl px-3 py-2 text-sm font-extrabold text-slate-700 transition hover:bg-white">
                                <span>إدارة البيانات</span>
                                <span class="text-xs text-slate-500 transition group-open:rotate-180">⌄</span>
                            </summary>
                            <div class="mt-2 space-y-1">
                                <a asp-area="Admin" asp-controller="Users" asp-action="Admins" class="@GetNavClass("Users", "Admins")">
                                    <span>حسابات الأدمن</span>
                                </a>
                                <a asp-area="Admin" asp-controller="Users" asp-action="Members" class="@GetNavClass("Users", "Members")">
                                    <span>المستخدمين</span>
                                </a>
                            </div>
                        </details>
                    </nav>

                    <div class="mt-6 border-t border-slate-200 pt-4">
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-full rounded-xl bg-rose-600 px-4 py-2.5 text-sm font-bold text-white transition hover:bg-rose-700">تسجيل الخروج</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <p class="text-sm font-bold text-slate-700">الوصول للوحة الإدارة يتطلب حساب Admin.</p>
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="mt-3 inline-flex rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">دخول المدير</a>
                    </div>
                }
            </aside>

            <div class="space-y-4">
                <header class="rounded-3xl border border-slate-200 bg-white px-5 py-4 shadow-sm sm:px-6">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <p class="text-xs font-bold tracking-[0.2em] text-admin-700">ADMIN PANEL</p>
                            <h1 class="mt-1 text-xl font-extrabold text-slate-900">@pageTitle</h1>
                        </div>

                        @if (isAuthenticated && !isDashboardPage)
                        {
                            <a asp-area="Member" asp-controller="Home" asp-action="Index" class="rounded-xl border border-admin-300 bg-admin-50 px-4 py-2 text-sm font-bold text-admin-700 transition hover:bg-admin-100">العودة للصفحة الرئيسية</a>
                        }
                    </div>
                </header>

                <main role="main" class="pb-4">
                    @RenderBody()
                </main>

                <footer class="rounded-2xl border border-slate-200 bg-white px-5 py-4 text-xs text-slate-500 shadow-sm sm:px-6">
                    <div class="flex flex-wrap items-center justify-between gap-2">
                        <p>Admin Panel &copy; @DateTime.Now.Year</p>
                        <p>Data Management | Store Management | Secure Access</p>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
