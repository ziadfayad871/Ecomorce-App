                var dictionaryKeys = Object.keys(dictionary).sort(function (a, b) { return b.length - a.length; });

                translateValue = function (text) {
                    if (!text) return text;
                    var result = String(text);
                    dictionaryKeys.forEach(function (key) {
                        if (result.indexOf(key) !== -1) {
                            result = result.split(key).join(dictionary[key]);
                        }
                    });
                    return result;
                };

                document.documentElement.lang = "en";
                document.documentElement.dir = "ltr";
                document.body.classList.add("lang-en");
                document.title = translateValue(document.title);

                document.querySelectorAll("[dir='rtl']").forEach(function (el) {
                    el.setAttribute("dir", "ltr");
                });

                ["title", "aria-label", "placeholder", "data-tooltip"].forEach(function (attr) {
                    document.querySelectorAll("[" + attr + "]").forEach(function (el) {
                        var value = el.getAttribute(attr);
                        var translated = translateValue(value);
                        if (translated !== value) {
                            el.setAttribute(attr, translated);
                        }
                    });
                });

                var walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT);
                var textNode;
                while ((textNode = walker.nextNode())) {
                    var parent = textNode.parentElement;
                    if (!parent) continue;
                    var tag = parent.tagName;
                    if (tag === "SCRIPT" || tag === "STYLE") continue;

                    var currentText = textNode.nodeValue;
                    var translatedText = translateValue(currentText);
                    if (translatedText !== currentText) {
                        textNode.nodeValue = translatedText;
                    }
                }
            }

            var desktopCollapsed = localStorage.getItem("admin.sidebar.collapsed") === "1";
            function isDesktop() { return window.matchMedia("(min-width: 1024px)").matches; }
            function getSidebarHiddenClass() { return currentLanguage === "en" ? "-translate-x-full" : "translate-x-full"; }
            function clearSidebarHiddenClasses() {
                if (!sidebar) return;
                sidebar.classList.remove("translate-x-full");
                sidebar.classList.remove("-translate-x-full");
            }

            function applySidebarState() {
                if (!sidebar || !mainWrapper) return;
                if (isDesktop()) {
                    clearSidebarHiddenClasses();
                    sidebar.classList.remove("lg:translate-x-full");
                    sidebar.classList.add("lg:translate-x-0");
                    sidebar.classList.toggle("sidebar-icons-only", desktopCollapsed);
                    mainWrapper.classList.toggle("sidebar-icons-only", desktopCollapsed);
                    sidebarBackdrop && sidebarBackdrop.classList.add("hidden");
                    document.body.classList.remove("overflow-hidden");
                } else {
                    sidebar.classList.remove("sidebar-icons-only");
                    mainWrapper.classList.remove("sidebar-icons-only");
                    sidebar.classList.remove("lg:translate-x-full");
                    sidebar.classList.add("lg:translate-x-0");
                    clearSidebarHiddenClasses();
                    sidebar.classList.add(getSidebarHiddenClass());
                    sidebarBackdrop && sidebarBackdrop.classList.add("hidden");
                    document.body.classList.remove("overflow-hidden");
                }

                sidebar.querySelectorAll("details").forEach(function (detail) {
                    detail.classList.remove("flyout-open");
                    if (desktopCollapsed && isDesktop()) {
                        detail.removeAttribute("open");
                    }
                });
            }

            function openMobileSidebar() {
                if (!sidebar || !sidebarBackdrop) return;
                clearSidebarHiddenClasses();
                sidebarBackdrop.classList.remove("hidden");
                document.body.classList.add("overflow-hidden");
            }
            function closeMobileSidebar() {
                if (!sidebar || !sidebarBackdrop) return;
                clearSidebarHiddenClasses();
                sidebar.classList.add(getSidebarHiddenClass());
                sidebarBackdrop.classList.add("hidden");
                document.body.classList.remove("overflow-hidden");
            }

            function closeMenus() {
                notificationsMenu && notificationsMenu.classList.add("hidden");
                accountMenu && accountMenu.classList.add("hidden");
                notificationsBtn && notificationsBtn.setAttribute("aria-expanded", "false");
                accountBtn && accountBtn.setAttribute("aria-expanded", "false");
            }

            function escapeHtml(value) {
                return String(value || "")
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#039;");
            }

            function positionToasts() {
                if (!toastContainer) return;
                var items = toastContainer.querySelectorAll(".notification");
                items.forEach(function (item) {
                    item.style.top = "";
                });
            }

            function hideToast(id) {
                var notification = document.getElementById(id);
                if (!notification) return;

                notification.classList.remove("show");
                notification.classList.add("hide");
                setTimeout(function () {
                    notification.remove();
                    positionToasts();
                }, 500);
            }

            function showNotification(isSuccess, message) {
                if (!toastContainer) return;
                var safeMessage = translateValue((message || "").toString().trim());
                if (!safeMessage) return;

                var notificationId = "notification-" + Date.now() + "-" + Math.floor(Math.random() * 1000);
                var notificationClass = isSuccess ? "success" : "error";
                var iconSymbol = isSuccess ? "✓" : "!";
                var duration = isSuccess ? 3000 : 5000;

                var notificationHTML =
                    "<div id='" + notificationId + "' class='notification " + notificationClass + "'>" +
                    "<span class='notification-icon'>" + iconSymbol + "</span>" +
                    "<span class='notification-message'>" + escapeHtml(safeMessage) + "</span>" +
                    "<button type='button' class='notification-close' data-hide-id='" + notificationId + "' aria-label='" + escapeHtml(translateValue("إغلاق")) + "'>" +
                    "×" +
                    "</button>" +
                    "<div class='notification-progress'><div class='notification-progress-bar'></div></div>" +
                    "</div>";

                toastContainer.insertAdjacentHTML("afterbegin", notificationHTML);
                var notification = document.getElementById(notificationId);
                var progressBar = notification ? notification.querySelector(".notification-progress-bar") : null;

                setTimeout(function () {
                    if (!notification) return;
                    notification.classList.add("show");
                    positionToasts();
                }, 100);

                setTimeout(function () {
                    hideToast(notificationId);
                }, duration);

                if (notification && progressBar) {
                    notification.addEventListener("mouseenter", function () {
                        progressBar.style.animationPlayState = "paused";
                    });
                    notification.addEventListener("mouseleave", function () {
                        progressBar.style.animationPlayState = "running";
                    });
                }
            }

            function seedValidationToasts() {
                var seen = {};
                var nodes = document.querySelectorAll(".validation-summary-errors li, .field-validation-error, [data-valmsg-for].text-danger");
                nodes.forEach(function (node) {
                    var text = (node.textContent || "").trim();
                    if (!text || seen[text]) return;
                    seen[text] = true;
                    showNotification(false, text);
                });
            }

            window.hideNotification = hideToast;

            sidebar && sidebar.addEventListener("click", function (event) {
                var summary = event.target.closest("summary");
                var detailFromSummary = summary && summary.parentElement && summary.parentElement.tagName === "DETAILS"
                    ? summary.parentElement
                    : null;

                if (detailFromSummary && isDesktop() && sidebar.classList.contains("sidebar-icons-only")) {
                    event.preventDefault();
                    var nextState = !detailFromSummary.classList.contains("flyout-open");
                    sidebar.querySelectorAll("details.flyout-open, details[open]").forEach(function (openDetail) {
                        openDetail.classList.remove("flyout-open");
                        openDetail.removeAttribute("open");
                    });
                    detailFromSummary.classList.toggle("flyout-open", nextState);
                    if (nextState) {
                        detailFromSummary.setAttribute("open", "");
                    } else {
                        detailFromSummary.removeAttribute("open");
                    }
                    return;
                }

                if (event.target.closest("details > div a") && isDesktop() && sidebar.classList.contains("sidebar-icons-only")) {
                    sidebar.querySelectorAll("details.flyout-open, details[open]").forEach(function (openDetail) {
                        openDetail.classList.remove("flyout-open");
                        openDetail.removeAttribute("open");
                    });
                }
            });

            function renderNotificationCount() {
                if (!notificationsBadge) return;
                notificationsBadge.textContent = notificationCount.toString();
                notificationsBadge.classList.toggle("hidden", notificationCount <= 0);
                notificationsBadge.classList.toggle("inline-flex", notificationCount > 0);
            }

            function showEmptyNotifications(show) {
                if (!emptyNotificationsMsg) return;
                emptyNotificationsMsg.classList.toggle("hidden", !show);
            }

            function addNotification(text, href) {
                if (!notificationsList || !text) return;
                var displayText = translateValue(text);

                showEmptyNotifications(false);
                var item = document.createElement("a");
                item.href = href || "#";
                item.className = "block border-b border-slate-100 px-3 py-2 transition hover:bg-slate-50";
                item.innerHTML =
                    "<p class='text-sm font-bold text-slate-800'>" + escapeHtml(displayText) + "</p>" +
                    "<p class='text-[11px] text-slate-500'>" + escapeHtml(translateValue("الآن")) + "</p>";
                notificationsList.prepend(item);
                notificationCount += 1;
                renderNotificationCount();
            }

            function clearNotifications() {
                if (!notificationsList) return;
                Array.from(notificationsList.querySelectorAll("a")).forEach(function (a) { a.remove(); });
                notificationCount = 0;
                renderNotificationCount();
                showEmptyNotifications(true);
            }

            toggleSidebarBtn && toggleSidebarBtn.addEventListener("click", function () {
                if (isDesktop()) {
                    desktopCollapsed = !desktopCollapsed;
                    localStorage.setItem("admin.sidebar.collapsed", desktopCollapsed ? "1" : "0");
                    applySidebarState();
                } else if (sidebar && sidebar.classList.contains("translate-x-full")) {
                    openMobileSidebar();
                } else {
                    closeMobileSidebar();
                }
            });
            closeSidebarBtn && closeSidebarBtn.addEventListener("click", closeMobileSidebar);
            sidebarBackdrop && sidebarBackdrop.addEventListener("click", closeMobileSidebar);
            window.addEventListener("resize", applySidebarState);
            applyLanguage();
            applySidebarState();

            notificationsBtn && notificationsBtn.addEventListener("click", function (e) {
                e.stopPropagation();
                var open = notificationsMenu && notificationsMenu.classList.contains("hidden");
                closeMenus();
                if (open && notificationsMenu) {
                    notificationsMenu.classList.remove("hidden");
                    notificationsBtn.setAttribute("aria-expanded", "true");
                }
            });

            clearNotificationsBtn && clearNotificationsBtn.addEventListener("click", function () {
                clearNotifications();
            });

            accountBtn && accountBtn.addEventListener("click", function (e) {
                e.stopPropagation();
                var open = accountMenu && accountMenu.classList.contains("hidden");
                closeMenus();
                if (open && accountMenu) {
                    accountMenu.classList.remove("hidden");
                    accountBtn.setAttribute("aria-expanded", "true");
                }
            });

            function openDeleteModal(form, message) {
                if (!deleteModal || !deleteModalMessage) return;
                pendingDeleteForm = form;
                deleteModalMessage.textContent = message || "هل أنت متأكد من تنفيذ الحذف؟";
                deleteModal.classList.remove("hidden");
                deleteModal.classList.add("flex");
                document.body.classList.add("overflow-hidden");
            }
            function closeDeleteModal() {
                if (!deleteModal) return;
                pendingDeleteForm = null;
                deleteModal.classList.add("hidden");
                deleteModal.classList.remove("flex");
                document.body.classList.remove("overflow-hidden");
            }

            document.addEventListener("click", function (event) {
                var closeToast = event.target.closest("[data-hide-id]");
                if (closeToast) {
                    hideToast(closeToast.getAttribute("data-hide-id"));
                    return;
                }

                if (isDesktop() && sidebar && sidebar.classList.contains("sidebar-icons-only") && !event.target.closest("#adminSidebar")) {
                    sidebar.querySelectorAll("details.flyout-open, details[open]").forEach(function (openDetail) {
                        openDetail.classList.remove("flyout-open");
                        openDetail.removeAttribute("open");
                    });
                }

                var trigger = event.target.closest("[data-delete-trigger]");
                if (trigger) {
                    var form = trigger.closest("form");
                    if (!form) return;
                    openDeleteModal(form, trigger.getAttribute("data-delete-message"));
                    return;
                }
                if (event.target.closest("[data-delete-close]") || event.target === deleteModalBackdrop) {
                    closeDeleteModal();
                    return;
                }
                if (!event.target.closest("#notificationsMenu") && !event.target.closest("#notificationsBtn") &&
                    !event.target.closest("#accountMenu") && !event.target.closest("#accountMenuBtn")) {
                    closeMenus();
                }
            });

            deleteModalConfirm && deleteModalConfirm.addEventListener("click", function () {
                if (pendingDeleteForm) pendingDeleteForm.submit();
            });

            document.addEventListener("keydown", function (event) {
                if ((event.key === "Enter" || event.key === " ") &&
                    event.target &&
                    event.target.matches &&
                    event.target.matches("#adminSidebar summary") &&
                    isDesktop() &&
                    sidebar &&
                    sidebar.classList.contains("sidebar-icons-only")) {
                    event.preventDefault();
                    var summaryTarget = event.target;
                    var detailTarget = summaryTarget.parentElement && summaryTarget.parentElement.tagName === "DETAILS"
                        ? summaryTarget.parentElement
                        : null;
                    if (!detailTarget) return;
                    var shouldOpen = !detailTarget.classList.contains("flyout-open");
                    sidebar.querySelectorAll("details.flyout-open, details[open]").forEach(function (openDetail) {
                        openDetail.classList.remove("flyout-open");
                        openDetail.removeAttribute("open");
                    });
                    detailTarget.classList.toggle("flyout-open", shouldOpen);
                    if (shouldOpen) {
                        detailTarget.setAttribute("open", "");
                    } else {
                        detailTarget.removeAttribute("open");
                    }
                    return;
                }

                if (event.key === "Escape") {
                    closeMobileSidebar();
                    closeDeleteModal();
                    closeMenus();
                }
            });

            window.adminAddNotification = function (text, href) {
                addNotification(text, href);
            };

            var seededNotifications = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(pendingNotifications));
            if (Array.isArray(seededNotifications)) {
                for (var i = seededNotifications.length - 1; i >= 0; i--) {
                    addNotification(seededNotifications[i], "#");
                }
            }
            renderNotificationCount();

            if (Array.isArray(flashItems)) {
                flashItems.forEach(function (item) {
                    showNotification(!(item && item.isError), item ? item.message : "");
                });
            }

            seedValidationToasts();

            document.querySelectorAll(".admin-table a, .admin-table button").forEach(function (el) {
                el.classList.add("admin-action-btn");
                var existingTitle = (el.getAttribute("title") || "").trim();
                if (!existingTitle) {
                    var label = (el.getAttribute("aria-label") || el.textContent || "").trim();
                    if (label) {
                        el.setAttribute("title", label);
                    }
                }
            });

        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

