@{
    var pageTitle = ViewData["Title"] as string ?? "لوحة إدارة متجر الملابس";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Ecomorce App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    colors: {
                        admin: {
                            50: "#ecfeff",
                            100: "#cffafe",
                            500: "#06b6d4",
                            700: "#0e7490",
                            900: "#164e63"
                        }
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Task.styles.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-slate-100 font-sans text-slate-800 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-28 right-10 h-96 w-96 rounded-full bg-admin-100 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 h-72 w-72 -translate-x-20 translate-y-20 rounded-full bg-cyan-200/70 blur-3xl"></div>
    </div>

    <div class="mx-auto flex min-h-screen max-w-7xl flex-col px-4 sm:px-6 lg:px-8">
        <header class="sticky top-0 z-20 border-b border-slate-200/70 bg-white/85 backdrop-blur">
            <div class="flex h-20 items-center justify-between gap-3">
                <div>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="text-xl font-extrabold text-admin-900">لوحة إدارة متجر الملابس</a>
                    <p class="text-xs font-semibold text-slate-500">إدارة التصنيفات والمنتجات والمستخدمين</p>
                </div>

                <nav class="flex flex-wrap items-center gap-2 text-sm font-bold">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-admin-500 hover:text-admin-700">الرئيسية</a>

                        <details class="relative">
                            <summary class="list-none cursor-pointer rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-admin-500 hover:text-admin-700">إدارة المتجر ▾</summary>
                            <div class="absolute left-0 z-30 mt-2 w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-lg">
                                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="block rounded-lg px-3 py-2 text-slate-700 transition hover:bg-admin-50 hover:text-admin-700">إدارة التصنيفات</a>
                                <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="mt-1 block rounded-lg px-3 py-2 text-slate-700 transition hover:bg-admin-50 hover:text-admin-700">إدارة المنتجات</a>
                                <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="mt-1 block rounded-lg px-3 py-2 text-slate-700 transition hover:bg-admin-50 hover:text-admin-700">إدارة المستخدمين</a>
                            </div>
                        </details>

                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-white shadow-sm transition hover:bg-rose-700">تسجيل الخروج</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="rounded-xl bg-admin-700 px-4 py-2 text-white shadow-sm transition hover:bg-admin-900">دخول المدير</a>
                    }
                </nav>
            </div>
        </header>

        <main role="main" class="flex-1 py-10">
            @RenderBody()
        </main>

        <footer class="mt-8 border-t border-slate-200/80 bg-white/70 px-4 py-8 backdrop-blur sm:px-6 lg:px-8">
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                    <p class="text-lg font-extrabold text-admin-900">لوحة الإدارة</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">تحكم كامل في المنتجات والتصنيفات والمستخدمين من مكان واحد.</p>
                </div>
                <div>
                    <p class="text-sm font-extrabold text-slate-900">إدارة المتجر</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="block transition hover:text-admin-700">المنتجات</a>
                        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="block transition hover:text-admin-700">التصنيفات</a>
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="block transition hover:text-admin-700">المستخدمون</a>
                    </div>
                </div>
                <div>
                    <p class="text-sm font-extrabold text-slate-900">الإحصائيات</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <p>متابعة تحديثات المنتجات لحظيا</p>
                        <p>تنظيم الكروت والصور داخل المتجر</p>
                        <p>تجربة إدارة سلسة وسريعة</p>
                    </div>
                </div>
                <div>
                    <p class="text-sm font-extrabold text-slate-900">الدعم التقني</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <p>Admin Support Center</p>
                        <p>admin-support@cloth-store.com</p>
                        <p>+20 100 111 2222</p>
                    </div>
                </div>
            </div>

            <div class="mt-6 flex flex-wrap items-center justify-between gap-2 border-t border-slate-200 pt-4 text-xs text-slate-500">
                <p>لوحة إدارة متجر الملابس &copy; @DateTime.Now.Year</p>
                <p>Operational Panel for Product & User Management</p>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
