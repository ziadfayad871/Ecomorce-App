@inject global::Core.Application.Common.Activities.IAdminActivityService ActivityService
@using System.Linq
@using System.Text.Json
@{
    var pageTitle = ViewData["Title"] as string ?? "لوحة الإدارة";
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var selectedLanguage = string.Equals(Context.Request.Cookies["Admin.Language"], "en", StringComparison.OrdinalIgnoreCase) ? "en" : "ar";
    var pageDir = selectedLanguage == "en" ? "ltr" : "rtl";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var userName = string.IsNullOrWhiteSpace(User.Identity?.Name) ? "مستخدم" : User.Identity!.Name!;
    var isProductsSection = string.Equals(currentController, "Products", StringComparison.OrdinalIgnoreCase);
    var isSectionsSection = string.Equals(currentController, "Categories", StringComparison.OrdinalIgnoreCase);
    var isUsersSection = string.Equals(currentController, "Users", StringComparison.OrdinalIgnoreCase);
    var isInsightsSection = string.Equals(currentController, "Dashboard", StringComparison.OrdinalIgnoreCase);
    var isOrdersReportsSection = isInsightsSection &&
        (string.Equals(currentAction, "Orders", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentAction, "Reports", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentAction, "Offers", StringComparison.OrdinalIgnoreCase));
    var isSettingsSection = string.Equals(currentController, "Settings", StringComparison.OrdinalIgnoreCase);
    var isMembersSection = isUsersSection &&
        (string.Equals(currentAction, "Members", StringComparison.OrdinalIgnoreCase)
        || string.Equals(currentAction, "EditMember", StringComparison.OrdinalIgnoreCase));
    var isLogsSection = isUsersSection && string.Equals(currentAction, "Logs", StringComparison.OrdinalIgnoreCase);
    var isLanguageSection = isSettingsSection && string.Equals(currentAction, "Language", StringComparison.OrdinalIgnoreCase);
    var isUsersMenuSection = isUsersSection &&
        !string.Equals(currentAction, "Members", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(currentAction, "EditMember", StringComparison.OrdinalIgnoreCase) &&
        !string.Equals(currentAction, "Logs", StringComparison.OrdinalIgnoreCase);
    var pendingNotifications = ActivityService
        .GetAll()
        .Take(40)
        .Select(x => x.Message)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();
    var flashMessages = new List<(string Message, bool IsError)>();

    bool IsLikelyError(string? message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return false;
        }

        var value = message.Trim();
        var errorWords = new[]
        {
            "خطأ", "فشل", "غير مسموح", "تعذر", "غير صالح", "Invalid", "Error", "Failed", "not allowed", "unable"
        };

        return errorWords.Any(x => value.Contains(x, StringComparison.OrdinalIgnoreCase));
    }

    void PushFlash(string? message, bool isError = false)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        flashMessages.Add((message.Trim(), isError));
    }

    var dashboardAction = TempData["DashboardAction"] as string;
    var productAction = TempData["ProductAction"] as string;
    var categoryAction = TempData["CategoryAction"] as string;
    var userAction = TempData["UserAction"] as string;
    var settingsAction = TempData["SettingsAction"] as string;
    var accountAction = TempData["AccountAction"] as string;

    PushFlash(dashboardAction, IsLikelyError(dashboardAction));
    PushFlash(productAction, IsLikelyError(productAction));
    PushFlash(categoryAction, IsLikelyError(categoryAction));
    PushFlash(userAction, IsLikelyError(userAction));
    PushFlash(settingsAction, IsLikelyError(settingsAction));
    PushFlash(accountAction, IsLikelyError(accountAction));

    PushFlash(TempData["DashboardError"] as string, true);
    PushFlash(TempData["ProductError"] as string, true);
    PushFlash(TempData["CategoryError"] as string, true);
    PushFlash(TempData["UserError"] as string, true);
    PushFlash(TempData["SettingsError"] as string, true);
    PushFlash(TempData["AccountError"] as string, true);
    PushFlash(TempData["Error"] as string, true);

    var flashMessagesJson = JsonSerializer.Serialize(
        flashMessages.Select(x => new { message = x.Message, isError = x.IsError })
    );

    string GetNavClass(string controller, string action)
    {
        var isActive =
            string.Equals(currentArea, "Admin", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        return isActive
            ? "group flex items-center gap-2 rounded-lg bg-admin-50 px-3 py-2 text-[13px] font-bold text-admin-800"
            : "group flex items-center gap-2 rounded-lg px-3 py-2 text-[13px] font-bold text-slate-700 transition hover:bg-slate-100 hover:text-admin-800";
    }

    string GetStateNavClass(bool isActive)
    {
        return isActive
            ? "group flex items-center gap-2 rounded-lg bg-admin-50 px-3 py-2 text-[13px] font-bold text-admin-800"
            : "group flex items-center gap-2 rounded-lg px-3 py-2 text-[13px] font-bold text-slate-700 transition hover:bg-slate-100 hover:text-admin-800";
    }
}
<!DOCTYPE html>
<html lang="@selectedLanguage" dir="@pageDir" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - مستخدم</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ["Cairo", "sans-serif"] },
                    colors: {
                        admin: {
                            50: "#f0f9ff",
                            100: "#e0f2fe",
                            200: "#bae6fd",
                            500: "#0ea5e9",
                            600: "#0284c7",
                            700: "#0369a1",
                            800: "#075985",
                            900: "#0c4a6e"
                        }
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Task.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-shell min-h-full bg-slate-100 font-sans text-slate-800 antialiased">
    <div class="notification-container"></div>
    <div id="adminFlashMessages" class="hidden" data-messages='@flashMessagesJson'></div>

    <header class="fixed inset-x-0 top-0 z-40 border-b border-slate-200 bg-white/95 shadow-2xl shadow-slate-300/70 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-[1800px] items-center justify-between px-3 sm:px-4 lg:px-6">
            <div class="flex items-center gap-2">
                <button id="toggleAdminSidebar" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 text-slate-600 transition hover:bg-slate-100" aria-label="القائمة">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </button>

                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white p-1.5 text-xs font-bold text-admin-800 transition hover:bg-slate-50" aria-label="الرئيسية">
                    <img src="~/img/store-logo.svg" alt="أناقة بلس" class="h-7 w-7 rounded-full object-cover" />
                </a>
            </div>

            <div class="flex items-center gap-2">
                <a asp-area="Admin" asp-controller="Settings" asp-action="Language" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-admin-700 transition hover:bg-admin-50 hover:border-admin-300" title="إعدادات اللغة" data-tooltip="إعدادات اللغة">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 5h12M9 3v2m2.5 0a13.5 13.5 0 0 1-3 7.5M5 17h6m-3-2v6m7-2.5 3-8 3 8m-5.4-2h4.8" />
                    </svg>
                </a>
                <div class="relative">
                    <button id="notificationsBtn" type="button" class="relative inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-admin-700 transition hover:bg-admin-50" aria-expanded="false">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2c0 .53-.2 1.04-.6 1.4L4 17h5m6 0v1a3 3 0 1 1-6 0v-1m6 0H9" />
                        </svg>
                        <span id="notificationsBadge" class="absolute -top-1 -left-1 hidden min-w-[16px] items-center justify-center rounded-full bg-admin-700 px-1 text-[10px] font-bold text-white">0</span>
                    </button>
                    <div id="notificationsMenu" class="absolute left-0 top-10 hidden w-80 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
                        <div class="flex items-center justify-between border-b border-slate-100 px-3 py-2">
                            <p class="text-xs font-bold text-slate-500">الإشعارات</p>
                            <button id="clearNotificationsBtn" type="button" class="rounded-md border border-slate-300 bg-white px-2 py-1 text-[11px] font-bold text-slate-700 transition hover:border-admin-300 hover:text-admin-700">حذف الكل</button>
                        </div>
                        <div id="notificationsList" class="max-h-72 overflow-auto">
                            <p id="emptyNotificationsMsg" class="px-3 py-6 text-center text-xs font-bold text-slate-500">لا توجد إشعارات حالياً</p>
                        </div>
                    </div>
                </div>

                <div class="relative">
                    <button id="accountMenuBtn" type="button" class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-2 py-1 text-xs font-bold text-slate-700 transition hover:bg-slate-50" aria-expanded="false">
                        <span class="account-avatar inline-flex h-7 w-7 items-center justify-center rounded-full bg-admin-100 text-admin-700">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 8a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm5 13a8 8 0 1 0-16 0h16Z" />
                            </svg>
                        </span>
                        <span class="account-name max-w-[110px] truncate">@userName</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="account-arrow h-3.5 w-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
                        </svg>
                    </button>
                    <div id="accountMenu" class="absolute left-0 top-10 hidden w-56 overflow-hidden rounded-2xl border border-slate-200 bg-white text-right shadow-xl">
                        <a asp-area="Admin" asp-controller="Settings" asp-action="Account" class="flex items-center gap-2 border-b border-slate-100 px-3 py-2 text-sm font-bold text-slate-700 transition hover:bg-slate-50">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 12a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm-7 8a7 7 0 0 1 14 0" />
                            </svg>
                            <span>إعدادات الحساب</span>
                        </a>
                        <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="p-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="inline-flex w-full items-center justify-center gap-1.5 rounded-lg border border-admin-700 bg-admin-700 px-2.5 py-1.5 text-xs font-bold text-white transition hover:bg-white hover:text-admin-700">تسجيل الخروج</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div id="sidebarBackdrop" class="fixed inset-0 z-40 hidden bg-slate-900/45 lg:hidden"></div>

    <aside id="adminSidebar" class="admin-sidebar-panel fixed inset-y-0 right-0 z-50 w-[280px] translate-x-full border-l border-slate-200 shadow-2xl transition-transform duration-300 lg:top-16 lg:translate-x-0">
        <div class="flex h-full flex-col p-3">
            <div class="sidebar-head mb-3 flex items-center justify-end lg:hidden">
                <button id="closeAdminSidebar" type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-500 shadow-sm hover:bg-slate-100" aria-label="إغلاق القائمة">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 6 12 12M18 6 6 18" />
                    </svg>
                </button>
            </div>

            @if (isAuthenticated)
            {
                <nav class="flex min-h-full flex-col gap-1.5">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="@GetNavClass("Dashboard", "Index")" title="الرئيسية" data-tooltip="الرئيسية">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 12h8V3H3v9Zm10 9h8v-6h-8v6Zm0-8h8V3h-8v10ZM3 21h8v-7H3v7Z" />
                        </svg>
                        <span class="nav-label">الرئيسية</span>
                    </a>

                    <details class="rounded-lg border border-slate-200 bg-white" @(isOrdersReportsSection ? "open" : null)>
                        <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 text-[13px] font-bold @(isOrdersReportsSection ? "bg-admin-50 text-admin-800" : "text-slate-700 hover:bg-slate-100")" title="الطلبات والتقارير" data-tooltip="الطلبات والتقارير" data-collapsed-href="@Url.Action("Orders", "Dashboard", new { area = "Admin" })">
                            <span class="flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 7h8m-8 4h6m-8 8h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H8L4 7v10a2 2 0 0 0 2 2Z" />
                                </svg>
                                <span class="nav-label">الطلبات والتقارير</span>
                            </span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="nav-arrow h-4 w-4 text-slate-400 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
                            </svg>
                        </summary>
                        <div class="space-y-1 px-2 pb-2">
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Orders" asp-route-range="today" class="@GetNavClass("Dashboard", "Orders")" title="إدارة الطلبات" data-tooltip="إدارة الطلبات">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 6h11l-1 12H8L7 6h2Zm-2 0h14M5 6l-1-2H2" />
                                </svg>
                                <span class="nav-label">إدارة الطلبات</span>
                            </a>
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Reports" class="@GetNavClass("Dashboard", "Reports")" title="تقارير المبيعات" data-tooltip="تقارير المبيعات">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 14h4v6H4v-6Zm6-5h4v11h-4V9Zm6-3h4v14h-4V6Z" />
                                </svg>
                                <span class="nav-label">تقارير المبيعات</span>
                            </a>
                            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Offers" class="@GetNavClass("Dashboard", "Offers")" title="العروض والكوبونات" data-tooltip="العروض والكوبونات">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 9V7a2 2 0 1 1 4 0v2m-6 1h12v9a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-9Z" />
                                </svg>
                                <span class="nav-label">العروض والكوبونات</span>
                            </a>
                        </div>
                    </details>

                    <details class="rounded-lg border border-slate-200 bg-white" @(isProductsSection ? "open" : null)>
                        <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 text-[13px] font-bold @(isProductsSection ? "bg-admin-50 text-admin-800" : "text-slate-700 hover:bg-slate-100")" title="إدارة المنتجات" data-tooltip="إدارة المنتجات" data-collapsed-href="@Url.Action("Index", "Products", new { area = "Admin" })">
                            <span class="flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m3 7.5 9 4.5 9-4.5M3 7.5 12 3l9 4.5M3 7.5V16.5L12 21m9-13.5V16.5L12 21m0 0v-9" />
                                </svg>
                                <span class="nav-label">إدارة المنتجات</span>
                            </span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="nav-arrow h-4 w-4 text-slate-400 transition group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
                            </svg>
                        </summary>
                        <div class="space-y-1 px-2 pb-2">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="@GetNavClass("Products", "Index")" title="المنتجات" data-tooltip="المنتجات">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m3 7.5 9 4.5 9-4.5M3 7.5 12 3l9 4.5M3 7.5V16.5L12 21m9-13.5V16.5L12 21m0 0v-9" />
                                </svg>
                                <span class="nav-label">المنتجات</span>
                            </a>
                            <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="@GetNavClass("Products", "Create")" title="إضافة منتج" data-tooltip="إضافة منتج">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 5v14m7-7H5" />
                                </svg>
                                <span class="nav-label">إضافة منتج</span>
                            </a>
                        </div>
                    </details>

                    <details class="rounded-lg border border-slate-200 bg-white" @(isSectionsSection ? "open" : null)>
                        <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2 text-[13px] font-bold @(isSectionsSection ? "bg-admin-50 text-admin-800" : "text-slate-700 hover:bg-slate-100")" title="إدارة الأقسام" data-tooltip="إدارة الأقسام" data-collapsed-href="@Url.Action("Index", "Categories", new { area = "Admin" })">
                            <span class="flex items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7a2 2 0 0 1 2-2h6l2 2h4a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z" />
                                </svg>
                                <span class="nav-label">إدارة الأقسام</span>
                            </span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="nav-arrow h-4 w-4 text-slate-400 transition group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m6 9 6 6 6-6" />
                            </svg>
                        </summary>
                        <div class="space-y-1 px-2 pb-2">
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="@GetNavClass("Categories", "Index")" title="الأقسام" data-tooltip="الأقسام">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7a2 2 0 0 1 2-2h6l2 2h4a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7Z" />
                                </svg>
                                <span class="nav-label">الأقسام</span>
                            </a>
                            <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="@GetNavClass("Categories", "Create")" title="إضافة قسم" data-tooltip="إضافة قسم">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 5v14m7-7H5" />
                                </svg>
                                <span class="nav-label">إضافة قسم</span>
                            </a>
                        </div>
                    </details>

                    <a asp-area="Admin" asp-controller="Users" asp-action="Members" class="@GetStateNavClass(isMembersSection)" title="عرض المشتركين" data-tooltip="عرض المشتركين">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
