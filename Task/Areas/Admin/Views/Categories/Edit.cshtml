@model global::Task.Areas.Admin.ViewModels.CategoryFormVm
@{
    ViewData["Title"] = "بيانات التصنيف";
}

<section class="mx-auto max-w-2xl">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-2xl font-extrabold text-slate-900">بيانات التصنيف</h1>

        <form asp-area="Admin" asp-controller="Categories" asp-action="Edit" method="post" class="mt-6 space-y-4">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

            <div>
                <label asp-for="Name" class="mb-1 block text-sm font-bold text-slate-700">اسم التصنيف</label>
                <input asp-for="Name" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="اسم التصنيف" />
                <span asp-validation-for="Name" class="mt-1 block text-xs font-semibold text-rose-600"></span>
            </div>

            <div class="flex flex-wrap gap-3">
                <button type="submit" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">حفظ</button>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-admin-500 hover:text-admin-700">رجوع</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
