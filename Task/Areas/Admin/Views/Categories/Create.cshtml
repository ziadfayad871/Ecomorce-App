@model global::Task.Areas.Admin.ViewModels.CategoryFormVm
@{
    ViewData["Title"] = "إضافة قسم";
}

<section class="w-full">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="page-title inline-flex w-full items-center gap-2 text-2xl font-extrabold text-slate-900">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 5v14m7-7H5" />
            </svg>
            إضافة قسم جديد
        </h1>
        <hr class="header-divider mt-3 border-slate-200" />

        <form asp-area="Admin" asp-controller="Categories" asp-action="Create" method="post" class="mt-6 space-y-4">
            <div asp-validation-summary="All" class="rounded-xl border border-admin-200 bg-admin-50 px-4 py-3 text-sm text-admin-700"></div>

            <div>
                <label asp-for="Name" class="mb-1 block text-sm font-bold text-slate-700">اسم القسم</label>
                <input asp-for="Name" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="مثال: ملابس" />
                <span asp-validation-for="Name" class="mt-1 block text-xs font-semibold text-rose-600"></span>
            </div>

            <div class="flex flex-wrap justify-center gap-3">
                <button type="submit" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">حفظ</button>
                <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-admin-500 hover:text-admin-700">رجوع</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
