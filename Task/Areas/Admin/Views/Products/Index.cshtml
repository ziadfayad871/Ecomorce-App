@model List<DataAccess.Models.Entities.Product>
@{
    ViewData["Title"] = "المنتجات";
}

<section class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-extrabold text-slate-900">بطاقات المنتجات</h1>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">إضافة منتج جديد</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-500">
            لا توجد منتجات حاليا. أضف أول منتج ليظهر ككارت في المتجر.
        </div>
    }
    else
    {
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var p in Model)
            {
                var img = p.Images?.FirstOrDefault()?.Path;
                <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
                    <div class="aspect-[3/4] w-full overflow-hidden bg-slate-100">
                        @if (!string.IsNullOrWhiteSpace(img))
                        {
                            <img src="@img" alt="@p.Name" class="h-full w-full object-cover" />
                        }
                        else
                        {
                            <div class="flex h-full items-center justify-center text-sm font-semibold text-slate-400">No Image</div>
                        }
                    </div>

                    <div class="space-y-3 p-4">
                        <div>
                            <p class="text-xs font-bold text-admin-700">@(p.Category?.Name ?? "بدون تصنيف")</p>
                            <h2 class="mt-1 text-lg font-extrabold text-slate-900">@p.Name</h2>
                            <p class="mt-1 text-sm font-bold text-slate-700">@p.Price.ToString("0.00") EGP</p>
                        </div>

                        <div class="flex items-center gap-2">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id" class="w-full rounded-xl border border-admin-300 px-3 py-2 text-center text-sm font-bold text-admin-700 transition hover:bg-admin-50">تعديل الكارت</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
