@model List<DataAccess.Models.Entities.Product>
@{
    ViewData["Title"] = "المنتجات";
}

<section class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-extrabold text-slate-900">بطاقات المنتجات</h1>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">إضافة منتج جديد</a>
    </div>

    @if (TempData["ProductAction"] is string msg)
    {
        <div class="rounded-2xl border border-admin-200 bg-admin-50 px-4 py-3 text-sm font-semibold text-admin-700">@msg</div>
    }

    @if (Model.Count == 0)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-500">
            لا توجد منتجات حاليا. أضف أول منتج ليظهر ككارت في المتجر.
        </div>
    }
    else
    {
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var p in Model)
            {
                var img = p.Images?.FirstOrDefault()?.Path;
                <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
                    <div class="aspect-[3/4] w-full overflow-hidden bg-slate-100">
                        @if (!string.IsNullOrWhiteSpace(img))
                        {
                            <img src="@img" alt="@p.Name" class="h-full w-full object-cover" />
                        }
                        else
                        {
                            <div class="flex h-full items-center justify-center text-sm font-semibold text-slate-400">No Image</div>
                        }
                    </div>

                    <div class="space-y-3 p-4">
                        <div>
                            <p class="text-xs font-bold text-admin-700">@(p.Category?.Name ?? "بدون تصنيف")</p>
                            <h2 class="mt-1 text-lg font-extrabold text-slate-900">@p.Name</h2>
                            <p class="mt-1 text-sm font-bold text-slate-700">@p.Price.ToString("0.00") EGP</p>
                        </div>

                        <div class="flex items-center justify-end gap-2">
                            <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id" title="تعديل" aria-label="تعديل" class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-admin-300 text-admin-700 transition hover:bg-admin-50">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m16.862 3.487 3.65 3.65m-2.121-2.122a2.5 2.5 0 1 1 3.536 3.536L7.5 22.978 2 24l1.022-5.5L16.39 5.015Z" />
                                </svg>
                            </a>

                            <form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post" class="inline" onsubmit="return confirm('حذف هذا المنتج؟');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@p.Id" />
                                <button type="submit" title="حذف" aria-label="حذف" class="inline-flex h-9 w-9 items-center justify-center rounded-xl border border-rose-300 text-rose-700 transition hover:bg-rose-50">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 6h18M8 6V4.75A1.75 1.75 0 0 1 9.75 3h4.5A1.75 1.75 0 0 1 16 4.75V6m-8 0h8m-7 3v9m3-9v9m3-9v9M5 6l1 14.25A1.75 1.75 0 0 0 7.75 22h8.5A1.75 1.75 0 0 0 18 20.25L19 6" />
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
