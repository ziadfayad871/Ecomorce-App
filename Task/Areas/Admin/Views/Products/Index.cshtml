@model List<DataAccess.Models.Entities.Product>
@{
    ViewData["Title"] = "المنتجات";
}

<section class="space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-extrabold text-slate-900">المنتجات</h1>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">إضافة منتج جديد</a>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-slate-600">
                <tr>
                    <th class="px-4 py-3 text-right font-bold">المنتج</th>
                    <th class="px-4 py-3 text-right font-bold">السعر</th>
                    <th class="px-4 py-3 text-right font-bold">التصنيف</th>
                    <th class="px-4 py-3 text-right font-bold">الصورة</th>
                    <th class="px-4 py-3 text-right font-bold">الإجراء</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-slate-500">لا توجد منتجات حالياً.</td>
                    </tr>
                }
                else
                {
                    @foreach (var p in Model)
                    {
                        var img = p.Images?.FirstOrDefault()?.Path;
                        <tr>
                            <td class="px-4 py-3 font-semibold text-slate-800">@p.Name</td>
                            <td class="px-4 py-3 text-slate-700">@p.Price</td>
                            <td class="px-4 py-3 text-slate-700">@p.Category?.Name</td>
                            <td class="px-4 py-3">
                                @if (!string.IsNullOrWhiteSpace(img))
                                {
                                    <img src="@img" alt="@p.Name" class="h-12 w-12 rounded-lg object-cover ring-1 ring-slate-200" />
                                }
                                else
                                {
                                    <span class="text-xs text-slate-400">بدون صورة</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@p.Id" class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-bold text-slate-700 transition hover:border-admin-500 hover:text-admin-700">تعديل</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
