@{
    ViewData["Title"] = "إدارة البيانات";
}

<section class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">إدارة البيانات</h1>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <a asp-area="Admin" asp-controller="Users" asp-action="Admins" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">DATA</p>
            <h2 class="mt-3 text-2xl font-extrabold text-slate-900">حسابات الأدمن</h2>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح الصفحة</span>
        </a>

        <a asp-area="Admin" asp-controller="Users" asp-action="Members" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">DATA</p>
            <h2 class="mt-3 text-2xl font-extrabold text-slate-900">المستخدمين</h2>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح الصفحة</span>
        </a>
    </div>
</section>
