@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<section class="space-y-5">
    <div class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <h1 class="page-title inline-flex items-center gap-2 text-lg font-extrabold text-admin-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 11a4 4 0 1 0-8 0 4 4 0 0 0 8 0ZM3 20a7 7 0 0 1 14 0M17 8h4m-2-2v4" />
            </svg>
            إدارة المستخدمين
        </h1>
        <hr class="header-divider mt-3 border-slate-200" />
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
        <a asp-area="Admin" asp-controller="Users" asp-action="Admins" class="group rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-200">
            <div class="flex items-center justify-between">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-admin-50 text-admin-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m12 3 7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4Z" />
                    </svg>
                </span>
                <span class="text-xs font-bold text-admin-700">فتح القسم</span>
            </div>
            <h2 class="mt-3 text-base font-extrabold text-slate-900">عرض المشرفين</h2>
        </a>

        <a asp-area="Admin" asp-controller="Users" asp-action="Members" class="group rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-200">
            <div class="flex items-center justify-between">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-admin-50 text-admin-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16 11a4 4 0 1 0-8 0 4 4 0 0 0 8 0ZM3 20a7 7 0 0 1 14 0" />
                    </svg>
                </span>
                <span class="text-xs font-bold text-admin-700">فتح القسم</span>
            </div>
            <h2 class="mt-3 text-base font-extrabold text-slate-900">عرض الأعضاء</h2>
        </a>

        <a asp-area="Admin" asp-controller="Users" asp-action="Roles" class="group rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-200">
            <div class="flex items-center justify-between">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-admin-50 text-admin-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6.5h16M4 12h16M4 17.5h16" />
                    </svg>
                </span>
                <span class="text-xs font-bold text-admin-700">فتح القسم</span>
            </div>
            <h2 class="mt-3 text-base font-extrabold text-slate-900">عرض المجموعات</h2>
        </a>

        <a asp-area="Admin" asp-controller="Users" asp-action="Logs" class="group rounded-2xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-200">
            <div class="flex items-center justify-between">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-admin-50 text-admin-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 7h8m-8 4h8m-8 4h5m-7 6h10a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H8l-4 4v12a2 2 0 0 0 2 2Z" />
                    </svg>
                </span>
                <span class="text-xs font-bold text-admin-700">فتح القسم</span>
            </div>
            <h2 class="mt-3 text-base font-extrabold text-slate-900">سجل العمليات</h2>
        </a>
    </div>
</section>
