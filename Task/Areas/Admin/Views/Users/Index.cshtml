@model global::Task.Areas.Admin.ViewModels.UsersIndexVm
@{
    ViewData["Title"] = "إدارة المستخدمين";
    var adminEmails = Model.AdminUsers
        .Select(x => x.Email?.Trim().ToLowerInvariant() ?? string.Empty)
        .ToHashSet();
}

<section class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">إدارة مستخدمي المتجر</h1>
        <p class="mt-3 text-sm text-slate-600">إدارة حسابات الميمبر + الترقية/الإرجاع من وإلى Admin.</p>
    </div>

    @if (TempData["UserAction"] is string msg)
    {
        <div class="rounded-2xl border border-admin-200 bg-admin-50 px-4 py-3 text-sm font-semibold text-admin-700">@msg</div>
    }

    <div class="flex flex-wrap items-center gap-2">
        <a asp-area="Admin" asp-controller="Users" asp-action="CreateAdmin" class="rounded-xl border border-admin-300 bg-admin-50 px-4 py-2 text-sm font-bold text-admin-700 transition hover:bg-admin-100">زرار إنشاء Admin</a>
        <a asp-area="Admin" asp-controller="Users" asp-action="CreateMember" class="rounded-xl border border-brand-300 bg-brand-50 px-4 py-2 text-sm font-bold text-brand-700 transition hover:bg-brand-100">زرار إنشاء User عادي</a>
    </div>

    <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-extrabold text-slate-900">حسابات الأدمن الحالية</h2>
        <p class="mt-1 text-sm text-slate-500">كل الحسابات اللي معاها صلاحية إدارة.</p>

        <div class="mt-4 space-y-2">
            @if (Model.AdminUsers.Count == 0)
            {
                <p class="rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-500">لا يوجد أي Admin حالياً.</p>
            }
            else
            {
                @foreach (var admin in Model.AdminUsers)
                {
                    <div class="flex items-center justify-between rounded-xl border border-slate-200 px-4 py-3">
                        <div>
                            <p class="text-sm font-bold text-slate-900">@(string.IsNullOrWhiteSpace(admin.FullName) ? "Admin" : admin.FullName)</p>
                            <p class="text-xs text-slate-500" dir="ltr">@admin.Email</p>
                        </div>
                        <span class="rounded-full bg-admin-50 px-2 py-1 text-xs font-bold text-admin-700">Admin</span>
                    </div>
                }
            }
        </div>
    </article>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-slate-600">
                <tr>
                    <th class="px-4 py-3 text-right font-bold">الاسم</th>
                    <th class="px-4 py-3 text-right font-bold">البريد الإلكتروني</th>
                    <th class="px-4 py-3 text-right font-bold">الحالة</th>
                    <th class="px-4 py-3 text-right font-bold">الصلاحية</th>
                    <th class="px-4 py-3 text-right font-bold">الإجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model.Members.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-4 py-8 text-center text-slate-500">لا يوجد مستخدمون حالياً.</td>
                    </tr>
                }
                else
                {
                    @foreach (var u in Model.Members)
                    {
                        var memberEmail = u.Email.Trim().ToLowerInvariant();
                        var isAdmin = adminEmails.Contains(memberEmail);

                        <tr>
                            <td class="px-4 py-3 font-semibold text-slate-800">@u.FullName</td>
                            <td class="px-4 py-3 text-slate-700" dir="ltr">@u.Email</td>
                            <td class="px-4 py-3">
                                @if (u.IsActive)
                                {
                                    <span class="rounded-full bg-emerald-50 px-2 py-1 text-xs font-bold text-emerald-700">Active</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-rose-50 px-2 py-1 text-xs font-bold text-rose-700">Blocked</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                @if (isAdmin)
                                {
                                    <span class="rounded-full bg-admin-50 px-2 py-1 text-xs font-bold text-admin-700">Admin</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-bold text-slate-600">Member</span>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap items-center gap-2">
                                    <form asp-area="Admin" asp-controller="Users" asp-action="ToggleBlock" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        @if (u.IsActive)
                                        {
                                            <button type="submit" class="rounded-lg border border-rose-300 px-3 py-1.5 text-xs font-bold text-rose-700 transition hover:bg-rose-50">Block</button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="rounded-lg border border-emerald-300 px-3 py-1.5 text-xs font-bold text-emerald-700 transition hover:bg-emerald-50">Unblock</button>
                                        }
                                    </form>

                                    @if (!isAdmin)
                                    {
                                        <form asp-area="Admin" asp-controller="Users" asp-action="PromoteMemberToAdmin" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="memberId" value="@u.Id" />
                                            <button type="submit" class="rounded-lg border border-admin-300 px-3 py-1.5 text-xs font-bold text-admin-700 transition hover:bg-admin-50">ترقية Admin</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-area="Admin" asp-controller="Users" asp-action="DemoteAdminToMember" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="memberId" value="@u.Id" />
                                            <button type="submit" class="rounded-lg border border-amber-300 px-3 py-1.5 text-xs font-bold text-amber-700 transition hover:bg-amber-50">رجوع User</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
