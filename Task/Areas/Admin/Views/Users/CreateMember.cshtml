@model global::Task.Areas.Admin.ViewModels.CreateMemberVm
@{
    ViewData["Title"] = "إنشاء User عادي";
}

<section class="mx-auto max-w-3xl">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-2xl font-extrabold text-slate-900">موديل إنشاء User عادي</h1>
        <p class="mt-2 text-sm text-slate-500">املأ البيانات لإنشاء حساب ميمبر عادي.</p>

        <form asp-area="Admin" asp-controller="Users" asp-action="CreateMember" method="post" class="mt-6 space-y-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

            <div>
                <label asp-for="FullName" class="mb-1 block text-sm font-bold text-slate-700">الاسم</label>
                <input asp-for="FullName" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="User Name" />
                <span asp-validation-for="FullName" class="mt-1 block text-xs font-semibold text-rose-600"></span>
            </div>

            <div>
                <label asp-for="Email" class="mb-1 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                <input asp-for="Email" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="user@example.com" />
                <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
            </div>

            <div>
                <label asp-for="Password" class="mb-1 block text-sm font-bold text-slate-700">كلمة المرور</label>
                <input asp-for="Password" type="password" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="••••••••" />
                <span asp-validation-for="Password" class="mt-1 block text-xs font-semibold text-rose-600"></span>
            </div>

            <div class="flex flex-wrap gap-3">
                <button type="submit" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">إنشاء المستخدم</button>
                <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-admin-500 hover:text-admin-700">رجوع</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
