@model global::Task.Areas.Admin.ViewModels.MemberEditVm
@{
    ViewData["Title"] = "تعديل العضو";
}

<section class="w-full space-y-5">
    <div class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <h1 class="page-title inline-flex items-center gap-2 text-lg font-extrabold text-admin-800">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="m16.862 3.487 3.65 3.65m-2.121-2.122a2.5 2.5 0 1 1 3.536 3.536L7.5 22.978 2 24l1.022-5.5L16.39 5.015Z" />
            </svg>
            تعديل العضو
        </h1>
        <hr class="header-divider mt-3 border-slate-200" />
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <form asp-area="Admin" asp-controller="Users" asp-action="EditMember" method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div asp-validation-summary="All" class="rounded-xl border border-admin-200 bg-admin-50 px-4 py-3 text-sm text-admin-700"></div>

            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <label asp-for="FullName" class="mb-1 block text-sm font-bold text-slate-700">الاسم</label>
                    <input asp-for="FullName" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
                    <span asp-validation-for="FullName" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Email" class="mb-1 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                    <input asp-for="Email" dir="ltr" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
                    <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>
            </div>

            <div class="grid gap-4 md:grid-cols-2">
                <div class="rounded-2xl border border-slate-200 bg-slate-50 p-3">
                    <p class="text-xs font-bold text-slate-500">تاريخ الإنشاء</p>
                    <p class="admin-stat-number mt-1 text-sm font-extrabold text-slate-800">@Model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
                </div>

                <label class="flex items-center justify-between rounded-2xl border border-slate-200 bg-slate-50 p-3">
                    <span class="text-sm font-bold text-slate-700">الحساب مفعّل</span>
                    <input asp-for="IsActive" class="h-4 w-4 rounded accent-admin-600" />
                </label>
            </div>

            <div class="flex flex-wrap justify-center gap-3">
                <button type="submit" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-900">حفظ التعديل</button>
                <a asp-area="Admin" asp-controller="Users" asp-action="Members" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-admin-500 hover:text-admin-700">رجوع</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
