@model global::Task.Areas.Admin.ViewModels.AdminLoginVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    ViewData["Title"] = "دخول الإدارة";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>دخول الإدارة - أناقة بلس</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        admin: {
                            50: "#f0f9ff",
                            100: "#e0f2fe",
                            500: "#0ea5e9",
                            600: "#0284c7",
                            700: "#0369a1",
                            800: "#075985",
                            900: "#0c4a6e"
                        }
                    },
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-white to-admin-100 font-sans antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-6xl items-center px-4 py-8">
        <section class="grid w-full gap-6 md:grid-cols-[1.05fr_0.95fr]">
            <div class="hidden rounded-3xl bg-gradient-to-br from-admin-900 via-admin-800 to-admin-600 p-8 text-white shadow-xl md:flex md:flex-col md:justify-between">
                <div>
                    <p class="text-xs font-bold tracking-[0.35em] text-sky-100">ADMIN PORTAL</p>
                    <h1 class="mt-4 text-4xl font-extrabold leading-tight">بوابة إدارة أناقة بلس</h1>
                    <p class="mt-4 max-w-md text-sm leading-7 text-sky-100">وصول خاص بالمشرفين لإدارة المنتجات، الطلبات، التقارير، وحسابات المستخدمين من لوحة تحكم واحدة متناسقة مع هوية النظام الحالية.</p>
                </div>
                <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur-sm">
                    <p class="text-sm font-bold"></p>
                    <p class="mt-2 text-sm text-sky-50"></p>
                </div>
            </div>

            <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-xl sm:p-8">
                <div class="flex items-center justify-between gap-3">
                    <a asp-area="Member" asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-2 rounded-full border border-slate-200 px-3 py-1.5 text-xs font-bold text-slate-600 transition hover:border-admin-300 hover:text-admin-700">
                        العودة للمتجر
                    </a>
                    <span class="inline-flex items-center rounded-full bg-admin-50 px-3 py-1 text-xs font-bold text-admin-700">للإدارة فقط</span>
                </div>

                <h2 class="mt-5 text-2xl font-extrabold text-slate-900">تسجيل دخول المشرف</h2>
                <p class="mt-2 text-sm text-slate-500">أدخل بيانات حساب الإدارة للمتابعة إلى لوحة التحكم.</p>

                <form asp-area="Admin" asp-controller="Account" asp-action="Login" method="post" class="mt-6 space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@((string?)ViewBag.ReturnUrl ?? string.Empty)" />

                    <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

                    <div>
                        <label asp-for="Email" class="mb-1 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                        <input asp-for="Email" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="admin@example.com" />
                        <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                    </div>

                    <div>
                        <label asp-for="Password" class="mb-1 block text-sm font-bold text-slate-700">كلمة المرور</label>
                        <div class="relative">
                            <input asp-for="Password" id="AdminLoginPasswordInput" type="password" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 pl-12 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="••••••••" />
                            <button type="button" data-toggle-target="AdminLoginPasswordInput" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 transition hover:text-slate-700" aria-label="إظهار كلمة المرور" aria-pressed="false">
                                <svg data-eye-open xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12S5.25 6.75 12 6.75 21.75 12 21.75 12 18.75 17.25 12 17.25 2.25 12 2.25 12Z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                                </svg>
                                <svg data-eye-closed xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3l18 18" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.584 10.587a2.25 2.25 0 1 0 3.182 3.182" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.88 5.09A10.477 10.477 0 0 1 12 4.875c6.75 0 9.75 5.25 9.75 5.25a17.27 17.27 0 0 1-3.015 3.83M6.228 6.228C4.068 7.545 2.25 10.125 2.25 10.125s3 5.25 9.75 5.25a10.9 10.9 0 0 0 4.27-.835" />
                                </svg>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                    </div>

                    <label class="flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-600">
                        <input asp-for="RememberMe" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-admin-700 focus:ring-admin-500" />
                        تذكرني
                    </label>

                    <button type="submit" class="w-full rounded-xl bg-admin-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-admin-900">دخول لوحة الإدارة</button>
                </form>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            document.querySelectorAll("[data-toggle-target]").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    var input = document.getElementById(btn.getAttribute("data-toggle-target"));
                    if (!input) return;
                    var isPassword = input.type === "password";
                    input.type = isPassword ? "text" : "password";
                    btn.setAttribute("aria-label", isPassword ? "إخفاء كلمة المرور" : "إظهار كلمة المرور");
                    btn.setAttribute("aria-pressed", isPassword ? "true" : "false");

                    var eyeOpen = btn.querySelector("[data-eye-open]");
                    var eyeClosed = btn.querySelector("[data-eye-closed]");
                    if (eyeOpen && eyeClosed) {
                        eyeOpen.classList.toggle("hidden", isPassword);
                        eyeClosed.classList.toggle("hidden", !isPassword);
                    }
                });
            });
        })();
    </script>
</body>
</html>
