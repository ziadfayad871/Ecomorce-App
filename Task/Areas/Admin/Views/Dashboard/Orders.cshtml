@using System.Globalization
@model global::Task.Areas.Admin.ViewModels.DashboardVm
@{
    ViewData["Title"] = "إدارة الطلبات";
    var culture = new CultureInfo("ar-EG");
    string FormatInt(int value) => value.ToString("N0", culture);
    string FormatMoney(decimal value) => $"{value.ToString("N2", culture)} EGP";
    var selectedRange = string.IsNullOrWhiteSpace(Model.SelectedRange) ? "30d" : Model.SelectedRange;

    string OrderStatusClass(string status) => status switch
    {
        "مكتمل" => "bg-emerald-50 text-emerald-700 border border-emerald-200",
        "قيد الشحن" => "bg-sky-50 text-sky-700 border border-sky-200",
        "ملغي" => "bg-rose-50 text-rose-700 border border-rose-200",
        _ => "bg-amber-50 text-amber-700 border border-amber-200"
    };
}

<section class="space-y-5 text-right" dir="rtl">
    <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <h1 class="inline-flex items-center gap-2 text-lg font-extrabold text-admin-800">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 7h8m-8 4h6m-8 8h12a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H8L4 7v10a2 2 0 0 0 2 2Z" />
                </svg>
                إدارة الطلبات
            </h1>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center rounded-xl border border-slate-300 px-3 py-2 text-sm font-bold text-slate-700 transition hover:border-admin-300 hover:text-admin-700">
                الرجوع للرئيسية
            </a>
        </div>
        <hr class="mt-3 border-slate-200" />

        <form method="get" asp-area="Admin" asp-controller="Dashboard" asp-action="Orders" class="mt-4 grid gap-3 md:grid-cols-4">
            <div>
                <label class="mb-1 block text-xs font-bold text-slate-600">الفترة</label>
                <select name="range" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100">
                    <option value="today" selected="@(selectedRange == "today" ? "selected" : null)">اليوم</option>
                    <option value="week" selected="@(selectedRange == "week" ? "selected" : null)">الأسبوع</option>
                    <option value="month" selected="@(selectedRange == "month" ? "selected" : null)">الشهر</option>
                    <option value="30d" selected="@(selectedRange == "30d" ? "selected" : null)">آخر 30 يوم</option>
                </select>
            </div>
            <div>
                <label class="mb-1 block text-xs font-bold text-slate-600">من تاريخ</label>
                <input type="date" name="from" value="@(Model.FromDate?.ToString("yyyy-MM-dd"))" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-bold text-slate-600">إلى تاريخ</label>
                <input type="date" name="to" value="@(Model.ToDate?.ToString("yyyy-MM-dd"))" class="w-full rounded-xl border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
            </div>
            <div class="flex items-end justify-end gap-2 md:col-span-4">
                <button type="submit" class="rounded-xl bg-admin-700 px-3 py-1.5 text-xs font-bold text-white transition hover:bg-admin-800">تحديث</button>
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Orders" class="rounded-xl border border-slate-300 px-3 py-1.5 text-xs font-bold text-slate-700 transition hover:border-admin-300 hover:text-admin-700">إلغاء</a>
            </div>
        </form>
    </article>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">إجمالي الطلبات</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-slate-900">@FormatInt(Model.OrdersCount)</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">طلبات اليوم</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-slate-900">@FormatInt(Model.OrdersToday)</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">طلبات معلّقة</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-amber-700">@FormatInt(Model.PendingOrdersCount)</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">طلبات متأخرة</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-rose-700">@FormatInt(Model.DelayedOrdersCount)</p>
        </article>
    </div>

    <article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <div class="mb-3 flex items-center justify-between">
            <h2 class="text-base font-extrabold text-admin-800">آخر 10 طلبات</h2>
            <span class="rounded-md bg-admin-50 px-2 py-1 text-xs font-bold text-admin-700">إجمالي المبيعات: @FormatMoney(Model.SalesTotal)</span>
        </div>
        <div class="overflow-hidden rounded-xl border border-slate-200">
            <table class="admin-table text-sm">
                <thead>
                    <tr>
                        <th class="px-4 py-3 font-bold">رقم الطلب</th>
                        <th class="px-4 py-3 font-bold">العميل</th>
                        <th class="px-4 py-3 font-bold">الإجمالي</th>
                        <th class="px-4 py-3 font-bold">الحالة</th>
                        <th class="px-4 py-3 font-bold">التاريخ</th>
                        <th class="px-4 py-3 font-bold">إجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentOrders.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-8 text-sm font-bold text-slate-500">لا توجد طلبات حديثة.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var order in Model.RecentOrders)
                        {
                            <tr>
                                <td class="px-4 py-3 font-semibold text-slate-800">@order.OrderNumber</td>
                                <td class="px-4 py-3 text-slate-700">@order.CustomerName</td>
                                <td class="px-4 py-3 admin-stat-number text-slate-700">@FormatMoney(order.Total)</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex rounded-full px-2 py-1 text-xs font-bold @OrderStatusClass(order.Status)">
                                        @order.Status
                                    </span>
                                </td>
                                <td class="px-4 py-3 admin-stat-number text-slate-700">@order.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="px-4 py-3">
                                    <a href="@(string.IsNullOrWhiteSpace(order.ViewUrl) ? "#" : order.ViewUrl)" class="admin-action-btn inline-flex items-center rounded-lg border border-admin-300 px-3 py-1 text-xs font-bold text-admin-700 transition hover:bg-admin-50" title="عرض الطلب" aria-label="عرض الطلب">عرض</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </article>
</section>
