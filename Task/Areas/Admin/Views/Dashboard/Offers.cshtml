@using System.Globalization
@model global::Task.Areas.Admin.ViewModels.DashboardVm
@{
    ViewData["Title"] = "العروض والكوبونات";
    var culture = new CultureInfo("ar-EG");
    string FormatInt(int value) => value.ToString("N0", culture);
}

<section class="space-y-5 text-right" dir="rtl">
    <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <h1 class="inline-flex items-center gap-2 text-lg font-extrabold text-admin-800">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-admin-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M8 9V7a2 2 0 1 1 4 0v2m-6 1h12v9a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-9Z" />
                </svg>
                إدارة العروض والكوبونات
            </h1>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="inline-flex items-center rounded-xl border border-slate-300 px-3 py-2 text-sm font-bold text-slate-700 transition hover:border-admin-300 hover:text-admin-700">
                الرجوع للرئيسية
            </a>
        </div>
        <hr class="mt-3 border-slate-200" />

        <form asp-area="Admin" asp-controller="Dashboard" asp-action="CreateOffer" method="post" class="mt-4 grid gap-3 md:grid-cols-2">
            @Html.AntiForgeryToken()
            <div>
                <label class="mb-1 block text-xs font-bold text-slate-600">عنوان العرض</label>
                <input name="title" class="w-full rounded-xl border border-slate-300 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="مثال: خصم العودة للمدارس" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-bold text-slate-600">كود الخصم</label>
                <input name="code" class="w-full rounded-xl border border-slate-300 text-sm uppercase outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" placeholder="CODE10" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-bold text-slate-600">نسبة الخصم %</label>
                <input name="discountPercent" type="number" step="0.01" min="0.01" max="100" class="w-full rounded-xl border border-slate-300 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
            </div>
            <div class="grid gap-3 sm:grid-cols-2">
                <div>
                    <label class="mb-1 block text-xs font-bold text-slate-600">بداية العرض</label>
                    <input name="startsAtUtc" type="datetime-local" class="w-full rounded-xl border border-slate-300 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
                </div>
                <div>
                    <label class="mb-1 block text-xs font-bold text-slate-600">نهاية العرض</label>
                    <input name="endsAtUtc" type="datetime-local" class="w-full rounded-xl border border-slate-300 text-sm outline-none transition focus:border-admin-500 focus:ring-2 focus:ring-admin-100" />
                </div>
            </div>
            <div class="md:col-span-2 flex items-center justify-between gap-3">
                <label class="inline-flex items-center gap-2 text-sm font-bold text-slate-700">
                    <input type="checkbox" name="isActive" value="true" checked class="rounded border-slate-300 text-admin-700 focus:ring-admin-500" />
                    تفعيل العرض فورًا
                </label>
                <button type="submit" class="rounded-xl bg-admin-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-admin-800">
                    حفظ العرض
                </button>
            </div>
        </form>
    </article>

    <div class="grid gap-3 sm:grid-cols-3">
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">إجمالي العروض</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-slate-900">@FormatInt(Model.Offers.Count)</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">العروض المفعلة</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-emerald-700">@FormatInt(Model.Offers.Count(x => x.IsActive))</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
            <p class="text-xs font-bold text-slate-600">العروض غير المفعلة</p>
            <p class="admin-stat-number mt-1 text-2xl font-extrabold text-rose-700">@FormatInt(Model.Offers.Count(x => !x.IsActive))</p>
        </article>
    </div>

    <article class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <h2 class="mb-3 text-base font-extrabold text-admin-800">قائمة العروض</h2>
        <div class="overflow-hidden rounded-xl border border-slate-200">
            <table class="admin-table text-sm">
                <thead>
                    <tr>
                        <th class="px-3 py-3 font-bold">العنوان</th>
                        <th class="px-3 py-3 font-bold">الكود</th>
                        <th class="px-3 py-3 font-bold">الخصم</th>
                        <th class="px-3 py-3 font-bold">الحالة</th>
                        <th class="px-3 py-3 font-bold">الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Offers.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-10 text-center font-semibold text-slate-500">لا توجد عروض حالياً.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var offer in Model.Offers)
                        {
                            <tr>
                                <td class="px-3 py-3 font-semibold text-slate-800">@offer.Title</td>
                                <td class="px-3 py-3"><span class="rounded-md bg-slate-100 px-2 py-1 text-xs font-bold text-slate-700">@offer.Code</span></td>
                                <td class="px-3 py-3 admin-stat-number text-slate-700">@offer.DiscountPercent.ToString("0.##")%</td>
                                <td class="px-3 py-3">
                                    @if (offer.IsActive)
                                    {
                                        <span class="inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-2 py-1 text-xs font-bold text-emerald-700">مفعل</span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex rounded-full border border-rose-200 bg-rose-50 px-2 py-1 text-xs font-bold text-rose-700">متوقف</span>
                                    }
                                </td>
                                <td class="px-3 py-3">
                                    <form asp-area="Admin" asp-controller="Dashboard" asp-action="ToggleOffer" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@offer.Id" />
                                        <button type="submit" class="admin-action-btn rounded-lg border border-admin-300 px-3 py-1 text-xs font-bold text-admin-700 transition hover:bg-admin-50" title="تغيير الحالة">
                                            @(offer.IsActive ? "إيقاف" : "تفعيل")
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </article>
</section>
