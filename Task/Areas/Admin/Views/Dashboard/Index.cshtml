@{
    ViewData["Title"] = "لوحة التحكم";
}

<section class="mx-auto max-w-5xl space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">مرحباً بك في لوحة الإدارة</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">تحكم في كل أقسام المتجر من مكان واحد: إدارة التصنيفات، إنشاء منتجات، وتحديث البيانات بسرعة.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">التصنيفات</p>
            <h2 class="mt-3 text-xl font-extrabold text-slate-900">إدارة التصنيفات</h2>
            <p class="mt-2 text-sm text-slate-600">أضف وعدّل تصنيفات المنتجات لتنظيم المتجر.</p>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح القسم</span>
        </a>

        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">المنتجات</p>
            <h2 class="mt-3 text-xl font-extrabold text-slate-900">إدارة المنتجات</h2>
            <p class="mt-2 text-sm text-slate-600">أنشئ المنتجات وحدّث الأسعار والصور والتصنيف.</p>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح القسم</span>
        </a>
    </div>
</section>
