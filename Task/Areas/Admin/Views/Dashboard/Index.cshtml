@model global::Task.Areas.Admin.ViewModels.DashboardVm
@{
    ViewData["Title"] = "Dashboard";
    var blockedCount = Model.MembersCount - Model.ActiveMembersCount;
}

<section class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">Dashboard</h1>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-6">
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold tracking-[0.2em] text-admin-700">التصنيفات</p>
            <p class="mt-3 text-3xl font-extrabold text-slate-900">@Model.DesignsCount</p>
            <p class="mt-1 text-sm text-slate-500">إجمالي التصنيفات</p>
        </article>

        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold tracking-[0.2em] text-admin-700">المنتجات</p>
            <p class="mt-3 text-3xl font-extrabold text-slate-900">@Model.ProductsCount</p>
            <p class="mt-1 text-sm text-slate-500">إجمالي المنتجات</p>
        </article>

        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold tracking-[0.2em] text-admin-700">المستخدمين</p>
            <p class="mt-3 text-3xl font-extrabold text-slate-900">@Model.MembersCount</p>
            <p class="mt-1 text-sm text-slate-500">إجمالي المستخدمين</p>
        </article>

        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-xs font-bold tracking-[0.2em] text-admin-700">الأدمن</p>
            <p class="mt-3 text-3xl font-extrabold text-slate-900">@Model.AdminsCount</p>
            <p class="mt-1 text-sm text-slate-500">إجمالي الأدمن</p>
        </article>

        <article class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 shadow-sm">
            <p class="text-xs font-bold tracking-[0.2em] text-emerald-700">نشط</p>
            <p class="mt-3 text-3xl font-extrabold text-emerald-800">@Model.ActiveMembersCount</p>
            <p class="mt-1 text-sm text-emerald-700">مستخدم نشط</p>
        </article>

        <article class="rounded-2xl border border-rose-200 bg-rose-50 p-5 shadow-sm">
            <p class="text-xs font-bold tracking-[0.2em] text-rose-700">محظور</p>
            <p class="mt-3 text-3xl font-extrabold text-rose-800">@blockedCount</p>
            <p class="mt-1 text-sm text-rose-700">مستخدم محظور</p>
        </article>
    </div>
</section>
