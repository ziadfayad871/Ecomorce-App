@{
    ViewData["Title"] = "لوحة التحكم";
}

<section class="mx-auto max-w-6xl space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">مرحباً بك في لوحة إدارة متجر الملابس</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">استخدم قائمة "إدارة المتجر" من أعلى الصفحة للتنقل السريع بين التصنيفات، المنتجات، والمستخدمين.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
        <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">التصنيفات</p>
            <h2 class="mt-3 text-xl font-extrabold text-slate-900">إدارة التصنيفات</h2>
            <p class="mt-2 text-sm text-slate-600">تنظيم أقسام الملابس في المتجر.</p>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح القسم</span>
        </a>

        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">المنتجات</p>
            <h2 class="mt-3 text-xl font-extrabold text-slate-900">إدارة المنتجات</h2>
            <p class="mt-2 text-sm text-slate-600">إضافة منتجات ملابس جديدة وتعديل الصور والأسعار.</p>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح القسم</span>
        </a>

        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-admin-400 hover:shadow-md">
            <p class="text-xs font-bold tracking-[0.25em] text-admin-700">المستخدمون</p>
            <h2 class="mt-3 text-xl font-extrabold text-slate-900">إدارة المستخدمين</h2>
            <p class="mt-2 text-sm text-slate-600">Block / Unblock لحسابات الميمبر حسب سياسة المتجر.</p>
            <span class="mt-4 inline-block text-sm font-bold text-admin-700">فتح القسم</span>
        </a>
    </div>
</section>
