@model List<global::Task.Areas.Member.ViewModels.CartItemVm>
@{
    ViewData["Title"] = "عربة التسوق";
    var total = Model.Sum(x => x.Total);
}

<section class="space-y-6">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <h1 class="text-3xl font-extrabold text-slate-900">عربة التسوق</h1>
        <p class="mt-3 text-sm text-slate-600">راجع منتجاتك، عدّل الكميات، وبعدها ادفع أونلاين عبر Stripe.</p>
    </div>

    @if (TempData["StoreSuccess"] is string okMsg)
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700">@okMsg</div>
    }

    @if (TempData["StoreError"] is string errMsg)
    {
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">@errMsg</div>
    }

    @if (Model.Count == 0)
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-500">
            العربة فارغة حاليا.
            <a asp-area="Member" asp-controller="Home" asp-action="Index" class="font-bold text-brand-700 hover:text-brand-900">تصفح المنتجات</a>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var item in Model)
            {
                <article class="flex flex-wrap items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                    <div class="h-20 w-20 overflow-hidden rounded-xl bg-slate-100">
                        @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                        {
                            <img src="@item.ImagePath" alt="@item.Name" class="h-full w-full object-cover" />
                        }
                        else
                        {
                            <div class="flex h-full items-center justify-center text-xs font-semibold text-slate-400">No Image</div>
                        }
                    </div>

                    <div class="min-w-[180px] flex-1">
                        <p class="text-xs font-bold text-brand-700">@item.CategoryName</p>
                        <h2 class="text-lg font-extrabold text-slate-900">@item.Name</h2>
                        <p class="text-sm text-slate-600">سعر القطعة: @item.UnitPrice.ToString("0.00") EGP</p>
                    </div>

                    <div class="flex items-center gap-2">
                        <form asp-area="Member" asp-controller="Home" asp-action="DecreaseQuantity" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="h-9 w-9 rounded-lg border border-slate-300 text-lg font-extrabold text-slate-700 transition hover:border-brand-500 hover:text-brand-700">-</button>
                        </form>

                        <span class="min-w-10 rounded-lg bg-slate-100 px-3 py-2 text-center text-sm font-bold text-slate-800">@item.Quantity</span>

                        <form asp-area="Member" asp-controller="Home" asp-action="IncreaseQuantity" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@item.ProductId" />
                            <button type="submit" class="h-9 w-9 rounded-lg border border-slate-300 text-lg font-extrabold text-slate-700 transition hover:border-brand-500 hover:text-brand-700">+</button>
                        </form>
                    </div>

                    <p class="min-w-[120px] text-sm font-bold text-slate-800">@item.Total.ToString("0.00") EGP</p>

                    <form asp-area="Member" asp-controller="Home" asp-action="RemoveFromCart" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@item.ProductId" />
                        <button type="submit" class="rounded-xl border border-rose-300 px-3 py-2 text-xs font-bold text-rose-700 transition hover:bg-rose-50">إزالة</button>
                    </form>
                </article>
            }
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm text-slate-600">الإجمالي</p>
            <p class="mt-1 text-2xl font-extrabold text-slate-900">@total.ToString("0.00") EGP</p>

            <form asp-area="Member" asp-controller="Home" asp-action="Checkout" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-emerald-700">الدفع الآن عبر Stripe</button>
            </form>
        </div>
    }
</section>
