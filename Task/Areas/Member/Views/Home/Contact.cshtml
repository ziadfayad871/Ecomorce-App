@model global::Task.Areas.Member.ViewModels.ContactFormVm
@{
    ViewData["Title"] = "تواصل معنا";
}

<section class="space-y-6">
    <div class="grid gap-6 lg:grid-cols-[1fr_1.1fr]">
        <div class="member-surface rounded-3xl p-6 sm:p-8">
            <h1 class="text-3xl font-black text-slate-900">تواصل معنا</h1>
            <p class="mt-3 text-sm leading-7 text-slate-600">
                لو عندك أي استفسار بخصوص الطلبات أو المنتجات، ابعتلنا رسالة وسنقوم بالرد عليك في أسرع وقت.
            </p>

            <div class="mt-6 space-y-3">
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                    <p class="text-xs font-black text-slate-500">البريد الإلكتروني</p>
                    <a href="mailto:support@anaka-plus.com" class="mt-1 inline-block text-sm font-bold text-[#0369a1] hover:underline">support@anaka-plus.com</a>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                    <p class="text-xs font-black text-slate-500">الهاتف</p>
                    <a href="tel:+201201055894" class="mt-1 inline-block text-sm font-bold text-[#0369a1] hover:underline">0123456789</a>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                    <p class="text-xs font-black text-slate-500">العنوان</p>
                    <p class="mt-1 text-sm font-bold text-slate-700"> Portsaid</p>
                </div>
                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                    <p class="text-xs font-black text-slate-500">مواعيد العمل</p>
                    <p class="mt-1 text-sm font-bold text-slate-700">السبت - الخميس | 10:00 ص - 8:00 م</p>
                </div>
            </div>
        </div>

        <div class="member-surface rounded-3xl p-6 sm:p-8">
            <h2 class="text-2xl font-black text-slate-900">أرسل رسالة</h2>
            <form asp-area="Member" asp-controller="Home" asp-action="Contact" method="post" class="mt-5 space-y-4">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700"></div>

                <div>
                    <label asp-for="FullName" class="mb-2 block text-sm font-bold text-slate-700">الاسم</label>
                    <input asp-for="FullName" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-[#0369a1] focus:ring-2 focus:ring-sky-100" placeholder="اكتب اسمك" />
                    <span asp-validation-for="FullName" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Email" class="mb-2 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                    <input asp-for="Email" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-[#0369a1] focus:ring-2 focus:ring-sky-100" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Subject" class="mb-2 block text-sm font-bold text-slate-700">عنوان الرسالة</label>
                    <input asp-for="Subject" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-[#0369a1] focus:ring-2 focus:ring-sky-100" placeholder="موضوع الرسالة" />
                    <span asp-validation-for="Subject" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Message" class="mb-2 block text-sm font-bold text-slate-700">الرسالة</label>
                    <textarea asp-for="Message" rows="6" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm font-medium outline-none transition focus:border-[#0369a1] focus:ring-2 focus:ring-sky-100" placeholder="اكتب رسالتك هنا..."></textarea>
                    <span asp-validation-for="Message" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <button type="submit" class="member-btn-primary rounded-xl px-6 py-3 text-sm">إرسال الرسالة</button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
