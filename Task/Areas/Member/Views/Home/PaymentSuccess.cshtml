@{
    ViewData["Title"] = "تم الدفع";
    var hasStripeSession = (bool?)ViewBag.HasStripeSession ?? false;
    var stripeSessionId = ViewBag.StripeSessionId as string;
}

<section class="mx-auto max-w-3xl">
    <div class="rounded-3xl border border-emerald-200 bg-white p-8 text-center shadow-sm">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100 text-3xl text-emerald-700">✓</div>
        <h1 class="mt-4 text-3xl font-extrabold text-slate-900">تم الدفع بنجاح</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">شكرا لطلبك. تم تأكيد العملية، وسيتم تحويلك للصفحة الرئيسية تلقائيا بعد <span id="countdown" class="font-extrabold text-emerald-700">30</span> ثانية.</p>

        @if (hasStripeSession && !string.IsNullOrWhiteSpace(stripeSessionId))
        {
            <p class="mt-4 rounded-xl bg-slate-50 px-4 py-2 text-xs font-semibold text-slate-500">Session ID: @stripeSessionId</p>
        }

        <div class="mt-6">
            <a asp-area="Member" asp-controller="Home" asp-action="Index" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-brand-900">الرجوع الآن للصفحة الرئيسية</a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    (function () {
        var remaining = 30;
        var countdown = document.getElementById("countdown");
        var timer = setInterval(function () {
            remaining--;
            if (countdown) {
                countdown.textContent = String(remaining);
            }

            if (remaining <= 0) {
                clearInterval(timer);
                window.location.href = "@Url.Action("Index", "Home", new { area = "Member" })";
            }
        }, 1000);
    })();
</script>
}
