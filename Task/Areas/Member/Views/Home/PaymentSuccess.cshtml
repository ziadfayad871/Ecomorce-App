@{
    ViewData["Title"] = "تم الدفع";
    var hasStripeSession = (bool?)ViewBag.HasStripeSession ?? false;
    var stripeSessionId = ViewBag.StripeSessionId as string;
}

<section class="mx-auto max-w-4xl py-4">
    <div class="member-surface rounded-3xl p-6 text-center sm:p-10">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-100 text-3xl text-emerald-700">✓</div>
        <h1 class="mt-4 text-3xl font-extrabold text-slate-900">تم الدفع بنجاح</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">شكراً لطلبك. سيتم تحويلك للصفحة الرئيسية تلقائياً بعد <span id="countdown" class="font-black text-emerald-700">30</span> ثانية.</p>

        @* @if (hasStripeSession && !string.IsNullOrWhiteSpace(stripeSessionId))
        {
            <p class="mt-4 rounded-xl bg-slate-50 px-4 py-2 text-xs font-semibold text-slate-500">Session ID: @stripeSessionId</p>
        } *@

        <div class="mt-6">
            <a asp-area="Member" asp-controller="Home" asp-action="Index" class="member-btn-primary inline-flex px-4 py-2.5 text-sm">الرجوع الآن للصفحة الرئيسية</a>
        </div>
    </div>
</section>

@section Scripts {
<script>
    (function () {
        var remaining = 30;
        var countdown = document.getElementById("countdown");
        var timer = setInterval(function () {
            remaining--;
            if (countdown) {
                countdown.textContent = String(remaining);
            }

            if (remaining <= 0) {
                clearInterval(timer);
                window.location.href = "@Url.Action("Index", "Home", new { area = "Member" })";
            }
        }, 1000);
    })();
</script>
}
