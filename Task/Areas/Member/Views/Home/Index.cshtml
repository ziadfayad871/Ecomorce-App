@model List<DataAccess.Models.Entities.Product>
@using Task.Areas.Member.ViewModels
@{
    ViewData["Title"] = "متجر الملابس";
    var categories = ViewBag.Categories as List<StoreCategoryFilterVm> ?? new List<StoreCategoryFilterVm>();
    int? selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    var selectedCategoryName = ViewBag.SelectedCategoryName as string ?? "كل المنتجات";
}

<section class="space-y-8">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <p class="inline-flex items-center rounded-full bg-brand-50 px-3 py-1 text-xs font-bold text-brand-700">CLOTHING STORE</p>
        <h1 class="mt-4 text-3xl font-extrabold text-slate-900">أحدث تشكيلات الملابس</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">تصفح كل المنتجات أو فلتر حسب القسم (رجالي، حريمي، أطفال...).</p>

        <div class="mt-5 flex flex-wrap gap-3">
            <a asp-area="Member" asp-controller="Home" asp-action="Cart" class="rounded-xl bg-brand-700 px-4 py-2 text-sm font-bold text-white transition hover:bg-brand-900">افتح العربة</a>
            <a asp-area="" asp-controller="Account" asp-action="Register" class="rounded-xl border border-brand-300 bg-brand-50 px-4 py-2 text-sm font-bold text-brand-700 transition hover:border-brand-500 hover:bg-brand-100">تسجيل مستخدم جديد</a>
        </div>
    </div>

    @if (TempData["StoreSuccess"] is string okMsg)
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-semibold text-emerald-700">@okMsg</div>
    }

    @if (TempData["StoreError"] is string errMsg)
    {
        <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">@errMsg</div>
    }

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="mb-3 text-sm font-bold text-slate-700">الأقسام</p>
        <div class="flex flex-wrap gap-2">
            <a asp-area="Member" asp-controller="Home" asp-action="Index" class="rounded-full px-4 py-2 text-sm font-bold transition @(selectedCategoryId == null ? "bg-brand-700 text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200")">الكل</a>

            @foreach (var c in categories)
            {
                <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-route-categoryId="@c.Id" class="rounded-full px-4 py-2 text-sm font-bold transition @(selectedCategoryId == c.Id ? "bg-brand-700 text-white" : "bg-slate-100 text-slate-700 hover:bg-slate-200")">
                    @c.Name (@c.Count)
                </a>
            }
        </div>
    </div>

    <div>
        <h2 class="mb-4 text-xl font-extrabold text-slate-900">@selectedCategoryName</h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            @if (Model.Count == 0)
            {
                <div class="col-span-full rounded-2xl border border-slate-200 bg-white p-8 text-center text-slate-500">
                    لا توجد منتجات في هذا القسم حاليا.
                </div>
            }
            else
            {
                @foreach (var p in Model)
                {
                    var image = p.Images.FirstOrDefault()?.Path;
                    <article class="group overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
                        <div class="aspect-[3/4] w-full overflow-hidden bg-slate-100">
                            @if (!string.IsNullOrWhiteSpace(image))
                            {
                                <img src="@image" alt="@p.Name" class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
                            }
                            else
                            {
                                <div class="flex h-full items-center justify-center text-sm font-semibold text-slate-400">No Image</div>
                            }
                        </div>

                        <div class="space-y-3 p-4">
                            <div>
                                <p class="text-xs font-bold text-brand-700">@(p.Category?.Name ?? "Clothing")</p>
                                <h2 class="mt-1 text-lg font-extrabold text-slate-900">@p.Name</h2>
                                <p class="mt-1 text-sm font-bold text-slate-700">@p.Price.ToString("0.00") EGP</p>
                            </div>

                            <form asp-area="Member" asp-controller="Home" asp-action="AddToCart" method="post" class="flex items-center gap-2">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@p.Id" />
                                <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                <button type="submit" class="w-full rounded-xl bg-brand-700 px-3 py-2 text-sm font-bold text-white transition hover:bg-brand-900">أضف للعربة</button>
                            </form>
                        </div>
                    </article>
                }
            }
        </div>
    </div>
</section>
