@{
    ViewData["Title"] = "لوحة العضو";
}

<section class="mx-auto max-w-4xl">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
        <p class="inline-flex items-center rounded-full bg-brand-50 px-3 py-1 text-xs font-bold text-brand-700">منطقة العضو</p>
        <h1 class="mt-4 text-3xl font-extrabold text-slate-900">أهلاً بك في لوحة العضو</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">تم تسجيل دخولك بنجاح. من هنا يمكنك متابعة حسابك والانتقال بسرعة إلى أقسام المتجر.</p>

        <div class="mt-6 flex flex-wrap gap-3">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-brand-500 hover:text-brand-700">لوحة الإدارة</a>
            <form asp-area="Member" asp-controller="Account" asp-action="Logout" method="post">
                <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-sm font-bold text-white transition hover:bg-rose-700">تسجيل الخروج</button>
            </form>
        </div>
    </div>
</section>
