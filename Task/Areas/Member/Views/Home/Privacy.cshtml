@{
    ViewData["Title"] = "سياسة الخصوصية";
}

<section class="mx-auto max-w-4xl py-2">
    <div class="member-surface rounded-3xl p-6 sm:p-8">
        <h1 class="text-2xl font-extrabold text-slate-900">سياسة الخصوصية</h1>
        <p class="mt-3 text-sm leading-7 text-slate-600">نحافظ على سرية بياناتك ونستخدمها فقط لتحسين تجربتك داخل المتجر وإتمام العمليات المرتبطة بحسابك.</p>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-sm font-bold text-slate-800">جمع البيانات</p>
                <p class="mt-2 text-sm text-slate-600">يتم استخدام بيانات الحساب والطلب لتجهيز مشترياتك وتسهيل المتابعة.</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-sm font-bold text-slate-800">حماية المعلومات</p>
                <p class="mt-2 text-sm text-slate-600">يتم التعامل مع البيانات عبر جلسات محمية وعمليات مصادقة آمنة.</p>
            </div>
        </div>
    </div>
</section>
