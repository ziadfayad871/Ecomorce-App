@{
    ViewData["Title"] = "من نحن";
}

<section class="space-y-6">
    <div class="member-surface overflow-hidden rounded-3xl p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[1.15fr_1fr] lg:items-center">
            <div>
                <span class="inline-flex rounded-full bg-sky-100 px-4 py-1 text-xs font-black text-[#0369a1]">أناقة بلس</span>
                <h1 class="mt-4 text-3xl font-black leading-tight text-slate-900 sm:text-4xl">قصتنا تبدأ من البساطة والذوق</h1>
                <p class="mt-4 text-sm leading-8 text-slate-600">
                    في أناقة بلس هدفنا نقدّم قطع عملية وأنيقة تناسب يومك، بجودة ممتازة وسعر عادل.
                    بنختار تشكيلاتنا بعناية علشان نوفرلك تجربة تسوق مريحة ومضمونة من أول تصفح لحد استلام الطلب.
                </p>

                <div class="mt-6 flex flex-wrap gap-3">
                    <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-fragment="product1" class="member-btn-primary rounded-xl px-5 py-2.5 text-sm">تسوق الآن</a>
                    <a asp-area="Member" asp-controller="Home" asp-action="Contact" class="member-btn-outline rounded-xl px-5 py-2.5 text-sm">تواصل معنا</a>
                </div>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <h2 class="text-xl font-black text-slate-900">رؤيتنا</h2>
                <p class="mt-3 text-sm leading-7 text-slate-600">
                    نكون اختيارك الأول للأزياء اليومية، بتصميمات عصرية وخدمة موثوقة.
                </p>

                <h3 class="mt-5 text-lg font-black text-slate-900">قيمنا</h3>
                <ul class="mt-3 space-y-2 text-sm font-semibold text-slate-600">
                    <li>الجودة قبل أي شيء</li>
                    <li>خدمة سريعة وواضحة</li>
                    <li>تجربة مستخدم سهلة وبسيطة</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <article class="member-surface rounded-2xl p-5 text-center">
            <p class="text-3xl font-black text-[#0369a1]">5K+</p>
            <p class="mt-2 text-sm font-bold text-slate-600">عميل سعيد</p>
        </article>
        <article class="member-surface rounded-2xl p-5 text-center">
            <p class="text-3xl font-black text-[#0369a1]">350+</p>
            <p class="mt-2 text-sm font-bold text-slate-600">منتج متنوع</p>
        </article>
        <article class="member-surface rounded-2xl p-5 text-center">
            <p class="text-3xl font-black text-[#0369a1]">24h</p>
            <p class="mt-2 text-sm font-bold text-slate-600">استجابة للدعم</p>
        </article>
        <article class="member-surface rounded-2xl p-5 text-center">
            <p class="text-3xl font-black text-[#0369a1]">99%</p>
            <p class="mt-2 text-sm font-bold text-slate-600">رضا العملاء</p>
        </article>
    </div>
</section>
