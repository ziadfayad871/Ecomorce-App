@model global::Task.Areas.Member.ViewModels.MemberLoginVm
@{
    ViewData["Title"] = "تسجيل الدخول";
}

<section class="mx-auto max-w-5xl">
    <div class="grid gap-6 md:grid-cols-[1.1fr_1fr]">
        <div class="hidden rounded-3xl bg-gradient-to-br from-brand-900 via-brand-700 to-sky-600 p-8 text-white md:flex md:flex-col md:justify-between">
            <div>
                <p class="text-xs font-bold tracking-[0.35em] text-sky-100">بوابة الأعضاء</p>
                <h1 class="mt-4 text-3xl font-extrabold leading-tight">مرحباً بعودتك</h1>
                <p class="mt-3 text-sm text-sky-100">سجّل الدخول لمتابعة طلباتك، تعديل بياناتك، والوصول إلى كل مزايا المتجر.</p>
            </div>
            <p class="text-sm text-sky-100"></p>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
            <h2 class="text-2xl font-extrabold text-slate-900">دخول الأعضاء</h2>
            <p class="mt-2 text-sm text-slate-500">اكتب بياناتك للمتابعة.</p>

            <form asp-area="Member" asp-controller="Account" asp-action="Login" method="post" class="mt-6 space-y-4">
                <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

                <div>
                    <label asp-for="Email" class="mb-1 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                    <input asp-for="Email" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Password" class="mb-1 block text-sm font-bold text-slate-700">كلمة المرور</label>
                    <div class="relative">
                        <input asp-for="Password" id="MemberLoginPasswordInput" type="password" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 pl-12 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100" placeholder="••••••••" />
                        <button type="button" data-toggle-target="MemberLoginPasswordInput" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 transition hover:text-slate-700" aria-label="إظهار كلمة المرور" aria-pressed="false">
                            <svg data-eye-open xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12S5.25 6.75 12 6.75 21.75 12 21.75 12 18.75 17.25 12 17.25 2.25 12 2.25 12Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                            </svg>
                            <svg data-eye-closed xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3l18 18" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.584 10.587a2.25 2.25 0 1 0 3.182 3.182" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.88 5.09A10.477 10.477 0 0 1 12 4.875c6.75 0 9.75 5.25 9.75 5.25a17.27 17.27 0 0 1-3.015 3.83M6.228 6.228C4.068 7.545 2.25 10.125 2.25 10.125s3 5.25 9.75 5.25a10.9 10.9 0 0 0 4.27-.835" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <label class="flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-600">
                    <input asp-for="RememberMe" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-brand-700 focus:ring-brand-500" />
                    تذكرني على هذا الجهاز
                </label>

                <button type="submit" class="w-full rounded-xl bg-brand-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-brand-900">تسجيل الدخول</button>
            </form>

            <p class="mt-5 text-sm text-slate-600">
                ليس لديك حساب؟
                <a asp-area="Member" asp-controller="Account" asp-action="Register" class="font-extrabold text-brand-700 hover:text-brand-900">أنشئ حساب جديد</a>
            </p>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var toggles = document.querySelectorAll("[data-toggle-target]");
            toggles.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    var input = document.getElementById(btn.getAttribute("data-toggle-target"));
                    if (!input) return;
                    var isPassword = input.type === "password";
                    input.type = isPassword ? "text" : "password";
                    btn.setAttribute("aria-label", isPassword ? "إخفاء كلمة المرور" : "إظهار كلمة المرور");
                    btn.setAttribute("aria-pressed", isPassword ? "true" : "false");

                    var eyeOpen = btn.querySelector("[data-eye-open]");
                    var eyeClosed = btn.querySelector("[data-eye-closed]");
                    if (eyeOpen && eyeClosed) {
                        eyeOpen.classList.toggle("hidden", isPassword);
                        eyeClosed.classList.toggle("hidden", !isPassword);
                    }
                });
            });
        })();
    </script>
}
