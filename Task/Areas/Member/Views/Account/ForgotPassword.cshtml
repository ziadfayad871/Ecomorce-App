@model global::Task.Areas.Member.ViewModels.MemberForgotPasswordVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    ViewData["Title"] = "نسيت كلمة المرور";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>نسيت كلمة المرور - أناقة بلس</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: "#eff6ff",
                            100: "#dbeafe",
                            600: "#0284c7",
                            700: "#0369a1",
                            800: "#075985",
                            900: "#0c4a6e"
                        }
                    },
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    boxShadow: {
                        soft: "0 20px 45px rgba(3, 105, 161, 0.14)"
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 via-white to-brand-100 font-sans antialiased">
    <main class="flex min-h-screen items-center justify-center px-4 py-6">
        <section class="w-full max-w-md rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-soft sm:p-7">
            <div class="text-center">
                <a asp-area="Member" asp-controller="Home" asp-action="Index" class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-brand-50 ring-4 ring-brand-100/70">
                    <img src="~/img/store-logo.svg" alt="أناقة بلس" class="h-10 w-10 object-contain" />
                </a>
                <h2 class="mt-3 text-2xl font-black text-brand-800">استعادة كلمة المرور</h2>
                <p class="mt-1 text-[13px] font-semibold leading-6 text-slate-500">اكتبي بريدك الإلكتروني وسنرسل لك رمز تحقق لتغيير كلمة المرور.</p>
            </div>

            <form asp-area="Member" asp-controller="Account" asp-action="ForgotPassword" method="post" id="memberForgotPasswordForm" class="mt-6 space-y-4">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700"></div>

                @if (TempData["StoreSuccess"] is string successMessage)
                {
                    <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700">@successMessage</div>
                }

                <div>
                    <label asp-for="Email" class="mb-1.5 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                    <input asp-for="Email" id="memberForgotPasswordEmail" dir="ltr" placeholder="name@example.com" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-brand-600 focus:bg-white focus:ring-4 focus:ring-brand-100" />
                    <span asp-validation-for="Email" class="mt-1 block text-xs font-bold text-rose-600"></span>
                </div>

                <button type="submit" id="memberForgotPasswordButton" class="flex w-full items-center justify-center gap-2 rounded-xl bg-brand-700 px-4 py-2.5 text-base font-extrabold text-white transition hover:bg-brand-900 disabled:cursor-not-allowed disabled:opacity-60" disabled>
                    <span id="memberForgotPasswordText">إرسال رمز التحقق</span>
                    <span id="memberForgotPasswordSpinner" class="hidden h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent"></span>
                </button>
            </form>

            <div class="mt-5 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-xs font-semibold leading-6 text-slate-600">
                بعد استلام الرمز افتحي صفحة التغيير وأدخلي الرمز مع كلمة المرور الجديدة.
            </div>

            <div class="mt-5 flex items-center justify-between gap-3 text-sm font-semibold text-slate-600">
                <a asp-area="Member" asp-controller="Account" asp-action="Login" class="text-brand-700 transition hover:text-brand-900 hover:underline">الرجوع لتسجيل الدخول</a>
                <a asp-area="Member" asp-controller="Account" asp-action="ResetPassword" class="text-slate-500 transition hover:text-slate-700 hover:underline">لديك رمز بالفعل؟</a>
            </div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            var form = document.getElementById("memberForgotPasswordForm");
            var emailInput = document.getElementById("memberForgotPasswordEmail");
            var button = document.getElementById("memberForgotPasswordButton");
            var text = document.getElementById("memberForgotPasswordText");
            var spinner = document.getElementById("memberForgotPasswordSpinner");
            var emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

            function updateState() {
                if (!button || !emailInput) return;
                var email = (emailInput.value || "").trim();
                button.disabled = !emailPattern.test(email);
            }

            emailInput && emailInput.addEventListener("input", updateState);

            form && form.addEventListener("submit", function () {
                if (!button) return;
                button.disabled = true;
                if (text) text.textContent = "جارٍ الإرسال...";
                if (spinner) spinner.classList.remove("hidden");
            });

            updateState();
        })();
    </script>
</body>
</html>
