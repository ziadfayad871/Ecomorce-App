@model global::Task.Areas.Member.ViewModels.MemberRegisterVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    ViewData["Title"] = "إنشاء حساب";
    var googleEnabled = ViewBag.GoogleEnabled as bool? ?? false;
    var microsoftEnabled = ViewBag.MicrosoftEnabled as bool? ?? false;
    var hasExternalProviders = googleEnabled || microsoftEnabled;
    var returnUrl = ViewBag.ReturnUrl as string ?? "/Member/Home/Index";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>إنشاء حساب - أناقة بلس</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            50: "#eff6ff",
                            100: "#dbeafe",
                            600: "#0284c7",
                            700: "#0369a1",
                            800: "#075985",
                            900: "#0c4a6e"
                        }
                    },
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    boxShadow: {
                        soft: "0 20px 45px rgba(3, 105, 161, 0.14)"
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="h-screen overflow-hidden bg-gradient-to-br from-slate-100 via-white to-brand-100 font-sans antialiased">
    <main class="flex h-screen items-center justify-center px-4 py-3">
        <section class="w-full max-w-md rounded-[1.5rem] border border-slate-200 bg-white p-6 shadow-soft sm:p-6">
            <div class="text-center">
                <a asp-area="Member" asp-controller="Home" asp-action="Index" class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-full bg-brand-50 ring-4 ring-brand-100/70">
                    <img src="~/img/store-logo.svg" alt="أناقة بلس" class="h-10 w-10 object-contain" />
                </a>
                <h2 class="mt-3 text-2xl font-black text-brand-800">إنشاء حساب جديد</h2>
                <p class="mt-1 text-[13px] font-semibold text-slate-500">سجّل الآن وابدأ تجربة التسوق داخل أناقة بلس</p>
            </div>

            <form asp-area="Member" asp-controller="Account" asp-action="Register" method="post" id="memberRegisterForm" class="mt-5 space-y-3">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700"></div>

                @if (TempData["LoginError"] is string externalError)
                {
                    <div class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs font-semibold text-rose-700">@externalError</div>
                }

                <div>
                    <label asp-for="FullName" class="mb-1.5 block text-sm font-bold text-slate-700">الاسم الكامل</label>
                    <input asp-for="FullName" id="memberRegisterName" placeholder="اكتب اسمك الكامل" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-brand-600 focus:bg-white focus:ring-4 focus:ring-brand-100" />
                    <span asp-validation-for="FullName" class="mt-1 block text-xs font-bold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Email" class="mb-1.5 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                    <input asp-for="Email" id="memberRegisterEmail" dir="ltr" placeholder="name@example.com" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-brand-600 focus:bg-white focus:ring-4 focus:ring-brand-100" />
                    <span asp-validation-for="Email" class="mt-1 block text-xs font-bold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Password" class="mb-1.5 block text-sm font-bold text-slate-700">كلمة المرور</label>
                    <input asp-for="Password" id="memberRegisterPassword" type="password" dir="ltr" placeholder="6 أحرف على الأقل" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-brand-600 focus:bg-white focus:ring-4 focus:ring-brand-100" />
                    <span asp-validation-for="Password" class="mt-1 block text-xs font-bold text-rose-600"></span>
                </div>

                <button type="submit" id="memberRegisterButton" class="flex w-full items-center justify-center gap-2 rounded-xl bg-brand-700 px-4 py-2.5 text-base font-extrabold text-white transition hover:bg-brand-900 disabled:cursor-not-allowed disabled:opacity-60" disabled>
                    <span id="memberRegisterText">إنشاء الحساب</span>
                    <span id="memberRegisterSpinner" class="hidden h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent"></span>
                </button>
            </form>

            <div class="my-4 flex items-center gap-3">
                <hr class="flex-1 border-slate-200" />
                <span class="text-xs font-bold text-slate-400">أو</span>
                <hr class="flex-1 border-slate-200" />
            </div>

            @if (hasExternalProviders)
            {
                <div class="space-y-2.5">
                    @if (googleEnabled)
                    {
                        <form asp-area="Member" asp-controller="Account" asp-action="ExternalLogin" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="provider" value="Google" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="flex w-full items-center justify-center gap-3 rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50 hover:shadow-sm" title="التسجيل باستخدام Google">
                                <img src="https://www.svgrepo.com/show/303108/google-icon-logo.svg" class="h-5 w-5" alt="Google" />
                                المتابعة باستخدام Google
                            </button>
                        </form>
                    }

                    @if (microsoftEnabled)
                    {
                        <form asp-area="Member" asp-controller="Account" asp-action="ExternalLogin" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="provider" value="Microsoft" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="flex w-full items-center justify-center gap-3 rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50 hover:shadow-sm" title="التسجيل باستخدام Microsoft">
                                <svg class="h-5 w-5" viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <rect x="1" y="1" width="9" height="9" fill="#f25022" />
                                    <rect x="11" y="1" width="9" height="9" fill="#7fba00" />
                                    <rect x="1" y="11" width="9" height="9" fill="#00a4ef" />
                                    <rect x="11" y="11" width="9" height="9" fill="#ffb900" />
                                </svg>
                                المتابعة باستخدام Microsoft
                            </button>
                        </form>
                    }
                </div>
            }

            <p class="mt-4 text-center text-sm font-semibold text-slate-600">
                لديك حساب بالفعل؟
                <a asp-area="Member" asp-controller="Account" asp-action="Login" class="font-black text-brand-700 hover:text-brand-900 hover:underline">تسجيل الدخول</a>
            </p>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            var form = document.getElementById("memberRegisterForm");
            var nameInput = document.getElementById("memberRegisterName");
            var emailInput = document.getElementById("memberRegisterEmail");
            var passwordInput = document.getElementById("memberRegisterPassword");
            var button = document.getElementById("memberRegisterButton");
            var text = document.getElementById("memberRegisterText");
            var spinner = document.getElementById("memberRegisterSpinner");
            var emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

            function updateState() {
                if (!button || !nameInput || !emailInput || !passwordInput) return;
                var fullName = (nameInput.value || "").trim();
                var email = (emailInput.value || "").trim();
                var password = passwordInput.value || "";
                button.disabled = !(fullName.length >= 3 && emailPattern.test(email) && password.length >= 6);
            }

            nameInput && nameInput.addEventListener("input", updateState);
            emailInput && emailInput.addEventListener("input", updateState);
            passwordInput && passwordInput.addEventListener("input", updateState);

            form && form.addEventListener("submit", function () {
                if (!button) return;
                button.disabled = true;
                if (text) text.textContent = "جارٍ إنشاء الحساب...";
                if (spinner) spinner.classList.remove("hidden");
            });

            updateState();
        })();
    </script>
</body>
</html>
