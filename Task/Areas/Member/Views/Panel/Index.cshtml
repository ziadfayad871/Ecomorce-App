@model global::Core.Application.Members.Models.MemberPanelVm
@{
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string StatusBadge(bool isActive)
        => isActive
            ? "inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700"
            : "inline-flex items-center rounded-full bg-rose-50 px-3 py-1 text-xs font-black text-rose-700";

    string OrderBadge(string status)
    {
        var normalized = status?.Trim().ToLowerInvariant() ?? string.Empty;
        if (normalized is "paid" or "completed") return "member-order-badge paid";
        if (normalized is "pending" or "processing") return "member-order-badge pending";
        if (normalized == "shipped") return "member-order-badge shipped";
        if (normalized is "cancelled" or "failed") return "member-order-badge cancelled";
        return "member-order-badge";
    }
}

<form id="memberFavoriteAntiForgery" class="hidden">@Html.AntiForgeryToken()</form>

<section class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[280px_minmax(0,1fr)]">
        @await Html.PartialAsync("_PanelSideNav")

        <div class="space-y-6">
            <section class="member-surface overflow-hidden rounded-3xl p-6">
                <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_220px] lg:items-center">
                    <div>
                        <span class="member-chip">لوحة متابعة حسابك</span>
                        <h1 class="mt-4 text-3xl font-black text-slate-900 sm:text-4xl">مرحبًا، @Model.FullName</h1>
                        <p class="mt-3 max-w-2xl text-sm font-semibold leading-8 text-slate-600">
                            هنا ستجد ملخص طلباتك، المنتجات التي تتابعها، وروابط سريعة لإدارة حسابك والتسوق بشكل أسرع.
                        </p>
                        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm font-bold text-slate-600">
                            <span class="@StatusBadge(Model.IsActive)">@(Model.IsActive ? "الحساب مفعل" : "الحساب غير مفعل")</span>
                            <span class="rounded-full bg-slate-100 px-3 py-1">عضو منذ @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</span>
                            @if (Model.LastOrderDateUtc.HasValue)
                            {
                                <span class="rounded-full bg-slate-100 px-3 py-1">آخر طلب @Model.LastOrderDateUtc.Value.ToLocalTime().ToString("dd MMM yyyy")</span>
                            }
                        </div>
                    </div>

                    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
                        <a asp-area="Member" asp-controller="Panel" asp-action="Orders" class="member-btn-primary flex items-center justify-center gap-2 px-4 py-3 text-sm">
                            <i class="fas fa-box-open"></i>
                            <span>متابعة الطلبات</span>
                        </a>
                        <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-fragment="product1" class="member-btn-outline flex items-center justify-center gap-2 px-4 py-3 text-sm">
                            <i class="fas fa-store"></i>
                            <span>العودة للتسوق</span>
                        </a>
                    </div>
                </div>
            </section>

            <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
                <article class="member-panel-stat-card">
                    <span class="member-panel-stat-icon bg-sky-100 text-sky-700"><i class="fas fa-sack-dollar"></i></span>
                    <div>
                        <p class="member-panel-stat-label">إجمالي الإنفاق</p>
                        <h2 class="member-panel-stat-value">@Model.TotalSpent.ToString("0.00") ج.م</h2>
                    </div>
                </article>
                <article class="member-panel-stat-card">
                    <span class="member-panel-stat-icon bg-amber-100 text-amber-700"><i class="fas fa-bag-shopping"></i></span>
                    <div>
                        <p class="member-panel-stat-label">عدد الطلبات</p>
                        <h2 class="member-panel-stat-value">@Model.OrdersCount</h2>
                    </div>
                </article>
                <article class="member-panel-stat-card">
                    <span class="member-panel-stat-icon bg-violet-100 text-violet-700"><i class="fas fa-hourglass-half"></i></span>
                    <div>
                        <p class="member-panel-stat-label">طلبات قيد المراجعة</p>
                        <h2 class="member-panel-stat-value">@Model.PendingOrdersCount</h2>
                    </div>
                </article>
                <article class="member-panel-stat-card">
                    <span class="member-panel-stat-icon bg-rose-100 text-rose-700"><i class="fas fa-heart"></i></span>
                    <div>
                        <p class="member-panel-stat-label">منتجات متابَعة</p>
                        <h2 class="member-panel-stat-value js-favorites-count">@Model.FavoritesCount</h2>
                    </div>
                </article>
                <article class="member-panel-stat-card">
                    <span class="member-panel-stat-icon bg-emerald-100 text-emerald-700"><i class="fas fa-cart-shopping"></i></span>
                    <div>
                        <p class="member-panel-stat-label">العربة الحالية</p>
                        <h2 class="member-panel-stat-value">@Model.CartItemsCount</h2>
                    </div>
                </article>
            </section>

            <section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
                <article class="member-surface rounded-3xl p-5">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-black text-slate-900">آخر الطلبات</h2>
                            <p class="mt-1 text-sm font-semibold text-slate-500">ملخص سريع لآخر عمليات الشراء من حسابك.</p>
                        </div>
                        <a asp-area="Member" asp-controller="Panel" asp-action="Orders" class="member-btn-outline px-4 py-2 text-sm">عرض الكل</a>
                    </div>

                    @if (Model.RecentOrders.Count == 0)
                    {
                        <div class="member-grid-empty mt-5 px-6 py-10 text-center text-sm font-bold text-slate-500">
                            لا توجد طلبات بعد. ابدأ التسوق وسيظهر سجل طلباتك هنا.
                        </div>
                    }
                    else
                    {
                        <div class="mt-5 overflow-x-auto">
                            <table class="min-w-full text-right">
                                <thead>
                                    <tr class="border-b border-slate-200 text-xs font-black uppercase tracking-wide text-slate-500">
                                        <th class="px-3 py-3">رقم الطلب</th>
                                        <th class="px-3 py-3">الحالة</th>
                                        <th class="px-3 py-3">العناصر</th>
                                        <th class="px-3 py-3">الإجمالي</th>
                                        <th class="px-3 py-3">التاريخ</th>
                                        <th class="px-3 py-3"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.RecentOrders)
                                    {
                                        <tr class="border-b border-slate-100 text-sm font-bold text-slate-700 last:border-0">
                                            <td class="px-3 py-4">@order.OrderNumber</td>
                                            <td class="px-3 py-4"><span class="@OrderBadge(order.Status)">@order.StatusDisplay</span></td>
                                            <td class="px-3 py-4">@order.ItemsCount</td>
                                            <td class="px-3 py-4">@order.TotalAmount.ToString("0.00") ج.م</td>
                                            <td class="px-3 py-4">@order.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                            <td class="px-3 py-4">
                                                <a asp-area="Member" asp-controller="Panel" asp-action="OrderDetails" asp-route-id="@order.Id" class="member-btn-outline inline-flex px-4 py-2 text-xs">عرض</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </article>

                <article class="member-surface rounded-3xl p-5">
                    <h2 class="text-xl font-black text-slate-900">وصول سريع</h2>
                    <p class="mt-1 text-sm font-semibold text-slate-500">أكثر الصفحات التي ستحتاجها خلال المتابعة والشراء.</p>
                    <div class="mt-5 grid gap-3">
                        <a asp-area="Member" asp-controller="Panel" asp-action="Favorites" class="member-panel-quick-link">
                            <i class="fas fa-heart"></i>
                            <span>إدارة المنتجات المتابعة</span>
                        </a>
                        <a asp-area="Member" asp-controller="Home" asp-action="Cart" class="member-panel-quick-link">
                            <i class="fas fa-cart-shopping"></i>
                            <span>مراجعة العربة الحالية</span>
                        </a>
                        <a asp-area="Member" asp-controller="Panel" asp-action="Profile" class="member-panel-quick-link">
                            <i class="fas fa-id-card"></i>
                            <span>تعديل بيانات الحساب</span>
                        </a>
                        <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-fragment="product1" class="member-panel-quick-link">
                            <i class="fas fa-store"></i>
                            <span>استكمال التسوق</span>
                        </a>
                    </div>
                </article>
            </section>

            <section class="grid gap-6 xl:grid-cols-2">
                <article class="member-surface rounded-3xl p-5">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-black text-slate-900">المنتجات التي تتابعها</h2>
                            <p class="mt-1 text-sm font-semibold text-slate-500">العناصر التي اخترت متابعتها للرجوع إليها سريعًا.</p>
                        </div>
                        <a asp-area="Member" asp-controller="Panel" asp-action="Favorites" class="member-btn-outline px-4 py-2 text-sm">الكل</a>
                    </div>

                    @if (Model.FavoriteProducts.Count == 0)
                    {
                        <div class="member-grid-empty mt-5 px-6 py-10 text-center text-sm font-bold text-slate-500">
                            لا توجد منتجات متابَعة بعد. من صفحة المتجر اضغط على أيقونة القلب لإضافتها هنا.
                        </div>
                    }
                    else
                    {
                        <div class="mt-5 grid gap-4 sm:grid-cols-2">
                            @foreach (var product in Model.FavoriteProducts)
                            {
                                var image = string.IsNullOrWhiteSpace(product.ImagePath) ? Url.Content("~/img/store-logo.svg") : product.ImagePath;
                                <article class="member-product-card" data-favorite-card="@product.ProductId">
                                    <img src="@image" alt="@product.Name" class="member-product-card-image" />
                                    <div class="member-product-card-body">
                                        <div class="flex items-start justify-between gap-3">
                                            <div>
                                                <p class="text-xs font-black text-slate-400">@product.CategoryName</p>
                                                <h3 class="mt-1 text-base font-black text-slate-900">@product.Name</h3>
                                            </div>
                                            <button type="button" class="favorite-toggle-btn member-favorite-chip is-tracked" data-product-id="@product.ProductId" data-is-tracked="true" aria-pressed="true" title="إلغاء المتابعة">
                                                <i class="fas fa-heart"></i>
                                            </button>
                                        </div>
                                        <div class="mt-3 flex items-center justify-between gap-3">
                                            <span class="text-sm font-black text-brand-700">@product.Price.ToString("0.00") ج.م</span>
                                            <span class="text-xs font-black @(product.StockQuantity > 0 ? "text-emerald-600" : "text-rose-600")">
                                                @(product.StockQuantity > 0 ? $"متوفر: {product.StockQuantity}" : "غير متوفر")
                                            </span>
                                        </div>
                                        <div class="mt-4 flex gap-2">
                                            <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-fragment="product1" class="member-btn-outline flex-1 px-4 py-2 text-center text-sm">فتح المتجر</a>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </article>

                <article class="member-surface rounded-3xl p-5">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <h2 class="text-xl font-black text-slate-900">اقتراحات لك</h2>
                            <p class="mt-1 text-sm font-semibold text-slate-500">منتجات جديدة يمكنك متابعتها أو استكشافها لاحقًا.</p>
                        </div>
                        <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-fragment="product1" class="member-btn-outline px-4 py-2 text-sm">المتجر</a>
                    </div>

                    @if (Model.SuggestedProducts.Count == 0)
                    {
                        <div class="member-grid-empty mt-5 px-6 py-10 text-center text-sm font-bold text-slate-500">
                            لا توجد اقتراحات حاليًا. جرّب زيارة المتجر لرؤية أحدث المنتجات.
                        </div>
                    }
                    else
                    {
                        <div class="mt-5 grid gap-4 sm:grid-cols-2">
                            @foreach (var product in Model.SuggestedProducts)
                            {
                                var image = string.IsNullOrWhiteSpace(product.ImagePath) ? Url.Content("~/img/store-logo.svg") : product.ImagePath;
                                <article class="member-product-card">
                                    <img src="@image" alt="@product.Name" class="member-product-card-image" />
                                    <div class="member-product-card-body">
                                        <div class="flex items-start justify-between gap-3">
                                            <div>
                                                <p class="text-xs font-black text-slate-400">@product.CategoryName</p>
                                                <h3 class="mt-1 text-base font-black text-slate-900">@product.Name</h3>
                                            </div>
                                            <button type="button" class="favorite-toggle-btn member-favorite-chip" data-product-id="@product.ProductId" data-is-tracked="false" aria-pressed="false" title="متابعة المنتج">
                                                <i class="far fa-heart"></i>
                                            </button>
                                        </div>
                                        <div class="mt-3 flex items-center justify-between gap-3">
                                            <span class="text-sm font-black text-brand-700">@product.Price.ToString("0.00") ج.م</span>
                                            <span class="text-xs font-black @(product.StockQuantity > 0 ? "text-emerald-600" : "text-rose-600")">
                                                @(product.StockQuantity > 0 ? $"متوفر: {product.StockQuantity}" : "غير متوفر")
                                            </span>
                                        </div>
                                        <div class="mt-4 flex gap-2">
                                            <a asp-area="Member" asp-controller="Home" asp-action="Index" asp-fragment="product1" class="member-btn-outline flex-1 px-4 py-2 text-center text-sm">استكشاف</a>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </article>
            </section>
        </div>
    </div>
</section>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.favorite-toggle-btn').forEach(function (button) {
            button.addEventListener('click', async function () {
                var productId = this.getAttribute('data-product-id');
                if (!productId || !window.memberStore) return;

                var result = await window.memberStore.toggleFavorite(productId, '@returnUrl');
                if (!result) return;

                if (result.requiresLogin && result.redirectUrl) {
                    window.location.href = result.redirectUrl;
                    return;
                }

                if (!result.success) {
                    showNotification(false, result.message || 'تعذر تحديث المتابعة');
                    return;
                }

                window.memberStore.setFavoriteButtonState(this, result.isTracked);
                document.querySelectorAll('.js-favorites-count').forEach(function (node) {
                    node.textContent = result.favoritesCount;
                });
                showNotification(true, result.message || 'تم تحديث المتابعة');
            });
        });
    });
</script>
}


