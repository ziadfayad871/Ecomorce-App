@{
    var pageTitle = ViewData["Title"] as string ?? "بوابة الأعضاء";
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Ecomorce App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    colors: {
                        brand: {
                            50: "#f0f9ff",
                            100: "#e0f2fe",
                            500: "#0ea5e9",
                            700: "#0369a1",
                            900: "#0c4a6e"
                        }
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Task.styles.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-slate-100 font-sans text-slate-800 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-24 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-brand-100 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-64 w-64 translate-x-20 translate-y-20 rounded-full bg-sky-200/70 blur-3xl"></div>
    </div>

    <div class="mx-auto flex min-h-screen max-w-7xl flex-col px-4 sm:px-6 lg:px-8">
        <header class="sticky top-0 z-20 border-b border-slate-200/70 bg-white/85 backdrop-blur">
            <div class="flex h-20 items-center justify-between gap-3">
                <div>
                    <a asp-area="Member" asp-controller="Home" asp-action="Index" class="text-xl font-extrabold text-brand-900">متجر إلكتروني</a>
                    <p class="text-xs font-semibold text-slate-500">بوابة الأعضاء</p>
                </div>

                <nav class="flex flex-wrap items-center gap-2 text-sm font-bold">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-area="Member" asp-controller="Home" asp-action="Index" class="rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-brand-500 hover:text-brand-700">لوحة العضو</a>
                        <form asp-area="Member" asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-white shadow-sm transition hover:bg-rose-700">تسجيل الخروج</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="Member" asp-controller="Account" asp-action="Login" class="rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-brand-500 hover:text-brand-700">تسجيل الدخول</a>
                        <a asp-area="Member" asp-controller="Account" asp-action="Register" class="rounded-xl bg-brand-700 px-4 py-2 text-white shadow-sm transition hover:bg-brand-900">إنشاء حساب</a>
                    }
                </nav>
            </div>
        </header>

        <main role="main" class="flex-1 py-10">
            @RenderBody()
        </main>

        <footer class="border-t border-slate-200/80 py-6 text-center text-sm text-slate-500">
            <p>جميع الحقوق محفوظة &copy; @DateTime.Now.Year</p>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
