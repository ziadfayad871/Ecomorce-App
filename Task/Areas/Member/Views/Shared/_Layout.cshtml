    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const mobileMenuBtn = document.getElementById('mobile-menu-btn');
            const mobileMenu = document.getElementById('mobile-menu');
            const backdrop = document.getElementById('mobile-menu-backdrop');
            const body = document.body;
            const desktopSearch = document.getElementById('desktop-store-search');
            const mobileSearch = document.getElementById('mobile-store-search');
            let isMenuOpen = false;

            function emitStoreSearch(term) {
                document.dispatchEvent(new CustomEvent('store-search', {
                    detail: { term: term || '' }
                }));
            }

            function syncSearch(source, target) {
                if (!source) return;
                source.addEventListener('input', function () {
                    if (target && target.value !== source.value) {
                        target.value = source.value;
                    }
                    emitStoreSearch(source.value);
                });
            }

            function toggleMenu() {
                if (!mobileMenu || !backdrop) return;
                isMenuOpen = !isMenuOpen;
                mobileMenu.classList.toggle('hidden', !isMenuOpen);
                backdrop.classList.toggle('hidden', !isMenuOpen);

                setTimeout(() => {
                    mobileMenu.classList.toggle('active', isMenuOpen);
                    backdrop.classList.toggle('active', isMenuOpen);
                    body.style.overflow = isMenuOpen ? 'hidden' : '';
                }, 10);
            }

            if (mobileMenuBtn) mobileMenuBtn.addEventListener('click', toggleMenu);
            if (backdrop) backdrop.addEventListener('click', toggleMenu);

            const menuLinks = document.querySelectorAll('#mobile-menu a');
            menuLinks.forEach(link => {
                link.addEventListener('click', () => {
                    if (isMenuOpen) toggleMenu();
                });
            });

            syncSearch(desktopSearch, mobileSearch);
            syncSearch(mobileSearch, desktopSearch);

            setTimeout(() => {
                const loading = document.getElementById('loading');
                if (loading) loading.classList.add('hidden');
            }, 500);

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && isMenuOpen) {
                    toggleMenu();
                }
            });
        });
    </script>

    <script>
        (function () {
            function getToken() {
                var tokenInput =
                    document.querySelector('#memberFavoriteAntiForgery input[name="__RequestVerificationToken"]') ||
                    document.querySelector('#ajaxAntiForgeryTemplate input[name="__RequestVerificationToken"]') ||
                    document.querySelector('input[name="__RequestVerificationToken"]');

                return tokenInput ? tokenInput.value : '';
            }

            function setFavoriteButtonState(button, isTracked) {
                if (!button) return;

                button.dataset.isTracked = String(!!isTracked);
                button.setAttribute('aria-pressed', isTracked ? 'true' : 'false');
                button.setAttribute('title', isTracked ? 'إلغاء المتابعة' : 'متابعة المنتج');
                button.classList.toggle('is-tracked', !!isTracked);

                var icon = button.querySelector('i');
                if (icon) {
                    icon.className = isTracked ? 'fas fa-heart' : 'far fa-heart';
                }
            }

            async function toggleFavorite(productId, returnUrl) {
                var token = getToken();
                var formData = new FormData();
                if (token) {
                    formData.append('__RequestVerificationToken', token);
                }

                formData.append('productId', productId);
                if (returnUrl) {
                    formData.append('returnUrl', returnUrl);
                }

                try {
                    var response = await fetch('/Member/Panel/ToggleFavorite', {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: formData
                    });

                    return await response.json();
                } catch {
                    return {
                        success: false,
                        message: 'تعذر الاتصال بالخادم حالياً.'
                    };
                }
            }

            window.memberStore = window.memberStore || {};
            window.memberStore.toggleFavorite = toggleFavorite;
            window.memberStore.setFavoriteButtonState = setFavoriteButtonState;
        })();
    </script>

    <script>
        (function () {
            const toastContainer = document.getElementById('memberToastContainer');
            if (!toastContainer) return;

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function hideToast(id) {
                const notification = document.getElementById(id);
                if (!notification) return;

                notification.classList.remove('show');
                notification.classList.add('hide');
                setTimeout(() => notification.remove(), 450);
            }

            function showToast(isSuccess, message) {
                const safeMessage = (message || '').toString().trim();
                if (!safeMessage) return;

                const notificationId = 'notification-' + Date.now() + '-' + Math.floor(Math.random() * 1000);
                const notificationClass = isSuccess ? 'success' : 'error';
                const iconClass = isSuccess ? 'fa-check-circle' : 'fa-exclamation-circle';
                const duration = isSuccess ? 3000 : 5000;

                const notificationHTML = `
                    <div id="${notificationId}" class="notification ${notificationClass}">
                        <i class="fas ${iconClass} notification-icon"></i>
                        <span class="notification-message">${escapeHtml(safeMessage)}</span>
                        <button type="button" class="notification-close" data-hide-id="${notificationId}" aria-label="إغلاق">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="notification-progress">
                            <div class="notification-progress-bar"></div>
                        </div>
                    </div>
                `;

                toastContainer.insertAdjacentHTML('afterbegin', notificationHTML);
                const notification = document.getElementById(notificationId);
                const progressBar = notification?.querySelector('.notification-progress-bar');

                setTimeout(() => {
                    notification?.classList.add('show');
                }, 50);

                setTimeout(() => {
                    hideToast(notificationId);
                }, duration);

                notification?.addEventListener('mouseenter', () => {
                    if (progressBar) progressBar.style.animationPlayState = 'paused';
                });

                notification?.addEventListener('mouseleave', () => {
                    if (progressBar) progressBar.style.animationPlayState = 'running';
                });
            }

            toastContainer.addEventListener('click', function (event) {
                const closeBtn = event.target.closest('[data-hide-id]');
                if (!closeBtn) return;
                const id = closeBtn.getAttribute('data-hide-id');
                if (id) hideToast(id);
            });

            window.showNotification = showToast;
            window.hideNotification = hideToast;

            const flashMessages = @Html.Raw(memberFlashMessagesJson);
            if (Array.isArray(flashMessages)) {
                flashMessages.forEach(item => {
                    if (!item || !item.message) return;
                    showToast(!(item.isError), item.message);
                });
            }
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

