@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Http
@using System.Linq
@using System.Text.Json
@{
    var pageTitle = ViewData["Title"] as string ?? "اناقة بلس";
    var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
    var memberAuth = await Context.AuthenticateAsync("MemberCookie");
    var isMemberAuthenticated = memberAuth.Succeeded;
    var memberName = memberAuth.Principal?.Identity?.Name;
    var currentPath = Context.Request.Path.Value ?? "";

    var isHomePage = currentPath.Equals("/Member/Home/Index", System.StringComparison.OrdinalIgnoreCase)
        || currentPath.Equals("/Member/Home", System.StringComparison.OrdinalIgnoreCase)
        || currentPath.Equals("/Member", System.StringComparison.OrdinalIgnoreCase)
        || currentPath.Equals("/", System.StringComparison.OrdinalIgnoreCase);
    var isCartPage = currentPath.Contains("/Member/Home/Cart", System.StringComparison.OrdinalIgnoreCase);
    var isAboutPage = currentPath.Contains("/Member/Home/About", System.StringComparison.OrdinalIgnoreCase);
    var isContactPage = currentPath.Contains("/Member/Home/Contact", System.StringComparison.OrdinalIgnoreCase);
    var isPanelPage = currentPath.Contains("/Member/Panel", System.StringComparison.OrdinalIgnoreCase);
    var isOrdersPage = currentPath.Contains("/Member/Panel/Orders", System.StringComparison.OrdinalIgnoreCase);
    var isFavoritesPage = currentPath.Contains("/Member/Panel/Favorites", System.StringComparison.OrdinalIgnoreCase);
    var isProfilePage = currentPath.Contains("/Member/Panel/Profile", System.StringComparison.OrdinalIgnoreCase);

    var memberFlashMessages = new List<(string Message, bool IsError)>();
    void PushFlash(string? message, bool isError = false)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        memberFlashMessages.Add((message.Trim(), isError));
    }

    PushFlash(TempData["StoreSuccess"] as string);
    PushFlash(TempData["ContactSuccess"] as string);
    PushFlash(TempData["Success"] as string);
    PushFlash(TempData["StoreError"] as string, true);
    PushFlash(TempData["ContactError"] as string, true);
    PushFlash(TempData["Error"] as string, true);

    var memberFlashMessagesJson = JsonSerializer.Serialize(
        memberFlashMessages.Select(x => new { message = x.Message, isError = x.IsError })
    );
}
