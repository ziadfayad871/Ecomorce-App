@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Http
@{
    var pageTitle = ViewData["Title"] as string ?? "بوابة متجر الملابس";
    var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
    var memberAuth = await Context.AuthenticateAsync("MemberCookie");
    var isMemberAuthenticated = memberAuth.Succeeded;
    var memberName = memberAuth.Principal?.Identity?.Name;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - Ecomorce App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    colors: {
                        brand: {
                            50: "#f0f9ff",
                            100: "#e0f2fe",
                            500: "#0ea5e9",
                            700: "#0369a1",
                            900: "#0c4a6e"
                        }
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Task.styles.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-slate-100 font-sans text-slate-800 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-24 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-brand-100 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-64 w-64 translate-x-20 translate-y-20 rounded-full bg-sky-200/70 blur-3xl"></div>
    </div>

    <div class="mx-auto flex min-h-screen max-w-7xl flex-col px-4 sm:px-6 lg:px-8">
        <header class="sticky top-0 z-20 border-b border-slate-200/70 bg-white/85 backdrop-blur">
            <div class="flex h-20 items-center justify-between gap-3">
                <div>
                    <a asp-area="Member" asp-controller="Home" asp-action="Index" class="text-xl font-extrabold text-brand-900">متجر الملابس</a>
                    <p class="text-xs font-semibold text-slate-500">تسوق سريع وآمن</p>
                </div>

                <nav class="flex flex-wrap items-center gap-2 text-sm font-bold">
                    <a asp-area="Member" asp-controller="Home" asp-action="Cart" class="rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-brand-500 hover:text-brand-700">العربة (@cartCount)</a>

                    @if (isMemberAuthenticated)
                    {
                        <span class="rounded-xl bg-brand-50 px-3 py-2 text-xs text-brand-700">حساب المستخدم: @(string.IsNullOrWhiteSpace(memberName) ? "Member" : memberName)</span>
                        <a asp-area="Member" asp-controller="Home" asp-action="Index" class="rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-brand-500 hover:text-brand-700">الرئيسية</a>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="rounded-xl bg-rose-600 px-4 py-2 text-white shadow-sm transition hover:bg-rose-700">تسجيل الخروج</button>
                        </form>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="Account" asp-action="Register" class="rounded-xl bg-brand-700 px-4 py-2 text-white shadow-sm transition hover:bg-brand-900">إنشاء حساب</a>
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="rounded-xl border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-brand-500 hover:text-brand-700">تسجيل الدخول</a>
                    }
                </nav>
            </div>
        </header>

        <main role="main" class="flex-1 py-10">
            @RenderBody()
        </main>

        <footer class="mt-8 border-t border-slate-200/80 bg-white/70 px-4 py-8 backdrop-blur sm:px-6 lg:px-8">
            <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                    <p class="text-lg font-extrabold text-brand-900">متجر الملابس</p>
                    <p class="mt-2 text-sm leading-6 text-slate-600">منصة تسوق ملابس حديثة مع تجربة شراء سريعة وآمنة.</p>
                </div>
                <div>
                    <p class="text-sm font-extrabold text-slate-900">روابط سريعة</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <a asp-area="Member" asp-controller="Home" asp-action="Index" class="block transition hover:text-brand-700">الرئيسية</a>
                        <a asp-area="Member" asp-controller="Home" asp-action="Cart" class="block transition hover:text-brand-700">عربة التسوق</a>
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="block transition hover:text-brand-700">تسجيل الدخول</a>
                        <a asp-area="" asp-controller="Account" asp-action="Register" class="block transition hover:text-brand-700">إنشاء حساب</a>
                    </div>
                </div>
                <div>
                    <p class="text-sm font-extrabold text-slate-900">خدمات المتجر</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <p>تصفح حسب الأقسام بسهولة</p>
                        <p>عربة تسوق ديناميكية وتحديث فوري</p>
                        <p>منتجات محدثة من لوحة الإدارة</p>
                    </div>
                </div>
                <div>
                    <p class="text-sm font-extrabold text-slate-900">الدعم</p>
                    <div class="mt-2 space-y-1 text-sm text-slate-600">
                        <p>السبت - الخميس: 9 ص - 9 م</p>
                        <p>support@cloth-store.com</p>
                        <p>+20 100 000 0000</p>
                    </div>
                </div>
            </div>

            <div class="mt-6 flex flex-wrap items-center justify-between gap-2 border-t border-slate-200 pt-4 text-xs text-slate-500">
                <p>متجر الملابس &copy; @DateTime.Now.Year. جميع الحقوق محفوظة.</p>
                <p>Designed for Modern Fashion Shopping</p>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

