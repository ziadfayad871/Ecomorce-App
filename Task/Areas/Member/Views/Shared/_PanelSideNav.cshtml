@{
    var currentAction = (ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty).ToLowerInvariant();
    string NavClass(string action, bool exact = true)
    {
        var active = exact ? currentAction == action.ToLowerInvariant() : currentAction.StartsWith(action.ToLowerInvariant());
        return active
            ? "member-panel-nav-link is-active"
            : "member-panel-nav-link";
    }
}

<aside class="member-surface rounded-3xl p-4 lg:sticky lg:top-28">
    <div class="rounded-2xl bg-sky-50 px-4 py-4 text-right">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white text-xl text-brand-700 shadow-sm">
            <i class="fas fa-user-circle"></i>
        </span>
        <h2 class="mt-3 text-lg font-black text-slate-900">كنترول بانل العضو</h2>
        <p class="mt-1 text-sm font-semibold leading-7 text-slate-500">تابع طلباتك ومنتجاتك المفضلة وحدّث بيانات حسابك من مكان واحد.</p>
    </div>

    <nav class="mt-4 space-y-2">
        <a asp-area="Member" asp-controller="Panel" asp-action="Index" class="@NavClass("index")">
            <i class="fas fa-chart-pie"></i>
            <span>الرئيسية</span>
        </a>
        <a asp-area="Member" asp-controller="Panel" asp-action="Orders" class="@NavClass("orders")">
            <i class="fas fa-bag-shopping"></i>
            <span>طلباتي</span>
        </a>
        <a asp-area="Member" asp-controller="Panel" asp-action="Favorites" class="@NavClass("favorites")">
            <i class="fas fa-heart"></i>
            <span>المنتجات المتابعة</span>
        </a>
        <a asp-area="Member" asp-controller="Panel" asp-action="Profile" class="@NavClass("profile")">
            <i class="fas fa-user-gear"></i>
            <span>الملف الشخصي</span>
        </a>
        <a asp-area="Member" asp-controller="Home" asp-action="Cart" class="member-panel-nav-link">
            <i class="fas fa-cart-shopping"></i>
            <span>العربة</span>
        </a>
        <a asp-area="Member" asp-controller="Home" asp-action="Contact" class="member-panel-nav-link">
            <i class="fas fa-headset"></i>
            <span>الدعم والتواصل</span>
        </a>
    </nav>
</aside>
