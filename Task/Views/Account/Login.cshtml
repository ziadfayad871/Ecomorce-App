@model global::Task.ViewModels.UnifiedLoginVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    var googleEnabled = ViewBag.GoogleEnabled as bool? ?? false;
    var microsoftEnabled = ViewBag.MicrosoftEnabled as bool? ?? false;
    var hasExternalProviders = googleEnabled || microsoftEnabled;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - Ecomorce App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            500: "#0369a1",
                            600: "#075985",
                            100: "#e0f2fe"
                        }
                    },
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-100 to-brand-100 font-sans antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-md items-center px-4 py-8">
        <section class="w-full rounded-2xl border border-slate-200 bg-white p-7 shadow-xl sm:p-8">
            <div class="text-center">
                <h1 class="text-3xl font-black text-brand-500">مرحبًا بعودتك</h1>
                <p class="mt-1 text-sm font-semibold text-slate-500">سجّل الدخول إلى حسابك</p>
            </div>

            @if (TempData["LoginError"] is string extErr)
            {
                <div class="mt-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-700">@extErr</div>
            }

            <form id="loginForm" asp-action="Login" method="post" class="mt-6 space-y-4">
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

                <div>
                    <label asp-for="Email" class="mb-2 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                    <input asp-for="Email" id="loginEmail" dir="ltr" placeholder="اكتب بريدك الإلكتروني" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-medium outline-none transition focus:border-brand-500 focus:bg-white focus:ring-2 focus:ring-brand-100" />
                    <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div>
                    <label asp-for="Password" class="mb-2 block text-sm font-bold text-slate-700">كلمة المرور</label>
                    <div class="relative">
                        <input asp-for="Password" id="loginPassword" type="password" dir="ltr" placeholder="اكتب كلمة المرور" class="w-full rounded-xl border border-slate-300 px-4 py-2.5 pl-11 text-sm font-medium outline-none transition focus:border-brand-500 focus:bg-white focus:ring-2 focus:ring-brand-100" />
                        <button type="button" data-toggle-target="loginPassword" class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 transition hover:text-slate-700" aria-label="إظهار كلمة المرور" aria-pressed="false">
                            <svg data-eye-open xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 12S5.25 6.75 12 6.75 21.75 12 21.75 12 18.75 17.25 12 17.25 2.25 12 2.25 12Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
                            </svg>
                            <svg data-eye-closed xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3l18 18" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.584 10.587a2.25 2.25 0 1 0 3.182 3.182" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.88 5.09A10.477 10.477 0 0 1 12 4.875c6.75 0 9.75 5.25 9.75 5.25a17.27 17.27 0 0 1-3.015 3.83M6.228 6.228C4.068 7.545 2.25 10.125 2.25 10.125s3 5.25 9.75 5.25a10.9 10.9 0 0 0 4.27-.835" />
                            </svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                </div>

                <div class="mt-1 flex items-center justify-between gap-3">
                    <label class="flex items-center gap-2 text-sm font-semibold text-slate-600">
                        <input asp-for="RememberMe" id="rememberMe" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-brand-500 focus:ring-brand-500" />
                        تذكرني
                    </label>
                    <span class="text-xs font-semibold text-slate-400">نسيت كلمة المرور؟ تواصل مع الدعم</span>
                </div>

                <button id="loginButton" type="submit" class="mt-1 flex w-full items-center justify-center gap-2 rounded-xl bg-brand-500 px-4 py-2.5 text-base font-bold text-white transition hover:bg-brand-600 disabled:cursor-not-allowed disabled:opacity-50" disabled>
                    <span id="loginButtonText">تسجيل الدخول</span>
                    <span id="loginSpinner" class="hidden h-4 w-4 animate-spin rounded-full border-2 border-white border-t-transparent"></span>
                </button>
            </form>

            @if (hasExternalProviders)
            {
                <div class="my-6 flex items-center gap-3">
                    <hr class="flex-1 border-slate-200" />
                    <span class="text-xs font-bold text-slate-500">أو</span>
                    <hr class="flex-1 border-slate-200" />
                </div>

                <div class="space-y-3">
                    @if (googleEnabled)
                    {
                        <form asp-action="ExternalLogin" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="provider" value="Google" />
                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50 hover:shadow-sm" title="تسجيل الدخول باستخدام Google">
                                <img src="https://www.svgrepo.com/show/303108/google-icon-logo.svg" class="h-5 w-5" alt="Google" />
                                المتابعة باستخدام Google
                            </button>
                        </form>
                    }

                    @if (microsoftEnabled)
                    {
                        <form asp-action="ExternalLogin" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="provider" value="Microsoft" />
                            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                            <button type="submit" class="flex w-full items-center justify-center gap-2 rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 transition hover:bg-slate-50 hover:shadow-sm" title="تسجيل الدخول باستخدام Microsoft">
                                <svg class="h-5 w-5" viewBox="0 0 21 21" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                    <rect x="1" y="1" width="9" height="9" fill="#f25022" />
                                    <rect x="11" y="1" width="9" height="9" fill="#7fba00" />
                                    <rect x="1" y="11" width="9" height="9" fill="#00a4ef" />
                                    <rect x="11" y="11" width="9" height="9" fill="#ffb900" />
                                </svg>
                                المتابعة باستخدام Microsoft
                            </button>
                        </form>
                    }
                </div>
            }

            <p class="mt-6 text-center text-sm font-semibold text-slate-600">
                لا تملك حسابًا؟
                <a asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl" class="font-black text-brand-500 hover:underline">إنشاء حساب</a>
            </p>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            var form = document.getElementById("loginForm");
            var emailInput = document.getElementById("loginEmail");
            var passwordInput = document.getElementById("loginPassword");
            var loginButton = document.getElementById("loginButton");
            var loginButtonText = document.getElementById("loginButtonText");
            var loginSpinner = document.getElementById("loginSpinner");
            var emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

            function updateSubmitState() {
                if (!emailInput || !passwordInput || !loginButton) {
                    return;
                }
                var email = (emailInput.value || "").trim();
                var password = passwordInput.value || "";
                var canSubmit = emailPattern.test(email) && password.length > 0;
                loginButton.disabled = !canSubmit;
            }

            function togglePassword(inputId, button) {
                var input = document.getElementById(inputId);
                if (!input) return;
                var isPassword = input.type === "password";
                input.type = isPassword ? "text" : "password";
                button.setAttribute("aria-label", isPassword ? "إخفاء كلمة المرور" : "إظهار كلمة المرور");
                button.setAttribute("aria-pressed", isPassword ? "true" : "false");

                var eyeOpen = button.querySelector("[data-eye-open]");
                var eyeClosed = button.querySelector("[data-eye-closed]");
                if (eyeOpen && eyeClosed) {
                    eyeOpen.classList.toggle("hidden", isPassword);
                    eyeClosed.classList.toggle("hidden", !isPassword);
                }
            }

            document.querySelectorAll("[data-toggle-target]").forEach(function (button) {
                button.addEventListener("click", function () {
                    togglePassword(button.getAttribute("data-toggle-target"), button);
                });
            });

            if (emailInput) {
                emailInput.addEventListener("input", updateSubmitState);
            }
            if (passwordInput) {
                passwordInput.addEventListener("input", updateSubmitState);
            }

            if (form) {
                form.addEventListener("submit", function () {
                    if (!loginButton) return;
                    loginButton.disabled = true;
                    if (loginButtonText) {
                        loginButtonText.textContent = "جارٍ تسجيل الدخول...";
                    }
                    if (loginSpinner) {
                        loginSpinner.classList.remove("hidden");
                    }
                });
            }

            updateSubmitState();
        })();
    </script>
</body>
</html>
