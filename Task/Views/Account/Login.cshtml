@model global::Task.ViewModels.UnifiedLoginVm
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>تسجيل الدخول - Ecomorce App</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ["Cairo", "sans-serif"]
                    },
                    colors: {
                        brand: {
                            500: "#0ea5e9",
                            700: "#0369a1",
                            900: "#0c4a6e"
                        }
                    }
                }
            }
        };
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="min-h-full bg-slate-100 font-sans text-slate-800 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
        <div class="absolute -top-24 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-sky-100 blur-3xl"></div>
        <div class="absolute bottom-0 right-0 h-72 w-72 translate-x-16 translate-y-16 rounded-full bg-cyan-200/70 blur-3xl"></div>
    </div>

    <div class="mx-auto flex min-h-screen max-w-6xl flex-col px-4 py-10 sm:px-6 lg:px-8">
        <main class="flex flex-1 items-center">
            <div class="grid w-full gap-6 md:grid-cols-[1.2fr_1fr]">
                <section class="hidden rounded-3xl bg-gradient-to-br from-brand-900 via-brand-700 to-cyan-500 p-8 text-white md:flex md:flex-col md:justify-between">
                    <div>
                        <p class="text-xs font-bold tracking-[0.35em] text-cyan-100">WELCOME</p>
                        <h1 class="mt-4 text-4xl font-extrabold leading-tight">تسجيل دخول موحد</h1>
                        <p class="mt-4 text-sm leading-7 text-cyan-100">
                            نفس الصفحة للميمبر والمدير.
                            النظام يحدد النوع تلقائيا بناء على الحساب ويحولك للوحة المناسبة.
                        </p>
                    </div>
                    <p class="text-sm text-cyan-100">Admin -> Dashboard | Member -> Home</p>
                </section>

                <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
                    <h2 class="text-2xl font-extrabold text-slate-900">تسجيل الدخول</h2>
                    <p class="mt-2 text-sm text-slate-500">استخدم البريد الإلكتروني وكلمة المرور الخاصة بحسابك.</p>

                    <form asp-action="Login" method="post" class="mt-6 space-y-4">
                        <input asp-for="ReturnUrl" type="hidden" />
                        <div asp-validation-summary="All" class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700"></div>

                        <div>
                            <label asp-for="Email" class="mb-1 block text-sm font-bold text-slate-700">البريد الإلكتروني</label>
                            <input asp-for="Email" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-sky-100" placeholder="name@example.com" />
                            <span asp-validation-for="Email" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                        </div>

                        <div>
                            <label asp-for="Password" class="mb-1 block text-sm font-bold text-slate-700">كلمة المرور</label>
                            <input asp-for="Password" type="password" dir="ltr" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-sky-100" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="mt-1 block text-xs font-semibold text-rose-600"></span>
                        </div>

                        <label class="flex cursor-pointer items-center gap-2 text-sm font-semibold text-slate-600">
                            <input asp-for="RememberMe" type="checkbox" class="h-4 w-4 rounded border-slate-300 text-brand-700 focus:ring-brand-500" />
                            تذكرني
                        </label>

                        <button type="submit" class="w-full rounded-xl bg-brand-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-brand-900">دخول</button>
                    </form>
                </section>
            </div>
        </main>

        <footer class="mt-8 rounded-2xl border border-slate-200 bg-white/80 px-6 py-5 text-sm text-slate-600 backdrop-blur">
            <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="font-semibold text-slate-700">Ecomorce App - Unified Access Portal</p>
                <p>Secure Login | Role-Based Redirect | @DateTime.Now.Year</p>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
